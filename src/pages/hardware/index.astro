---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { WaveformSection } from "../../components/audio/WaveformSection";

import { hardwareItems } from "../../data/hardware";
---

<BaseLayout title="Hardware | The Harmonic">
    <div class="min-h-screen flex flex-col font-sans bg-background selection:bg-accent selection:text-white relative">

        <main class="relative z-10 w-full max-w-[1600px] mx-auto px-4 md:px-8 lg:px-12 pt-40 pb-40 overflow-hidden flex-grow">

            {/* Aggressive Hardware Header */}
            <header class="w-full mb-20 relative">
                {/* Background Track */}
                <div class="absolute top-1/2 left-0 w-full h-[1px] bg-white/5 -translate-y-1/2 -z-10 hidden md:block"></div>

                <div class="inline-block bg-background pr-8 relative z-10">
                    <div class="flex items-center gap-3 mb-4">
                        <div class="w-2 h-2 bg-accent rounded-sm shadow-[0_0_12px_#ff6000] rotate-45"></div>
                        <span class="font-mono text-[10px] text-foreground/40 uppercase tracking-[0.3em] font-bold">Directory // 04</span>
                    </div>
                    <h1 class="font-serif text-6xl md:text-8xl lg:text-[7rem] tracking-tighter text-white leading-none drop-shadow-lg">
                        Physical <span class="text-accent italic">&</span> <br class="hidden md:block" /> Systems
                    </h1>
                </div>
            </header>

            {/* Hardware Filter / Status Bar */}
            <div class="flex flex-col md:flex-row justify-between items-start md:items-end gap-8 mb-16 relative bg-[#0c0c0e] p-6 md:p-8 rounded-[2rem] border border-white/[0.05] shadow-[0_20px_40px_rgba(0,0,0,0.4),inset_0_1px_1px_rgba(255,255,255,0.05)]">

                <div class="flex flex-wrap gap-3 font-mono text-[10px] tracking-[0.2em] uppercase font-bold">
                    <button class="bg-accent text-black px-6 py-3 rounded-xl shadow-[0_0_15px_rgba(255,96,0,0.3),inset_0_2px_4px_rgba(255,255,255,0.4)] transition-all">
                        All Tech
                    </button>
                    <button class="bg-[#151515] text-foreground/50 border border-white/10 px-6 py-3 rounded-xl hover:bg-white/5 hover:text-white transition-all shadow-[inset_0_2px_4px_rgba(0,0,0,0.5)]">
                        Synths
                    </button>
                    <button class="bg-[#151515] text-foreground/50 border border-white/10 px-6 py-3 rounded-xl hover:bg-white/5 hover:text-white transition-all shadow-[inset_0_2px_4px_rgba(0,0,0,0.5)]">
                        Drum Machines
                    </button>
                    <button class="bg-[#151515] text-foreground/50 border border-white/10 px-6 py-3 rounded-xl hover:bg-white/5 hover:text-white transition-all shadow-[inset_0_2px_4px_rgba(0,0,0,0.5)]">
                        Effects
                    </button>
                </div>

                {/* Technical Readout */}
                <div class="flex flex-col items-end gap-2 font-mono text-[9px] text-foreground/40 tracking-[0.25em] uppercase">
                    <div class="flex items-center gap-3">
                        <span>Display: Schematic</span>
                        <div class="flex gap-1 flex-col items-end w-4 h-4 justify-center">
                            <span class="w-full h-[1.5px] bg-accent shadow-[0_0_8px_#ff6000]"></span>
                            <span class="w-[70%] h-[1.5px] bg-white/20"></span>
                            <span class="w-[40%] h-[1.5px] bg-white/20"></span>
                        </div>
                    </div>
                    <span>Units_Found: 0{hardwareItems.length}</span>
                </div>
            </div>

            {/* The Hardware Schematic Grid */}
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12 relative z-10">
                {hardwareItems.map((item) => (
                    <a href={item.url} class="group relative flex flex-col transition-all duration-700 rounded-[2rem] md:rounded-[2.5rem] overflow-hidden bg-[#0c0c0e] border border-white/[0.04] hover:border-accent/40 shadow-[0_20px_40px_rgba(0,0,0,0.6)] hover:shadow-[0_0_60px_rgba(255,96,0,0.15)] hover:-translate-y-2">
                        {/* High-end hardware inner bezel */}
                        <div class="absolute inset-0 z-0 pointer-events-none rounded-[inherit] shadow-[inset_0_2px_2px_rgba(255,255,255,0.06),inset_0_-1px_1px_rgba(0,0,0,0.5)]"></div>

                        <div class="flex flex-col md:flex-row h-full w-full relative z-10">

                            {/* Image Section - Left */}
                            <div class="w-full md:w-1/2 relative bg-[#030303] p-2.5 md:p-3 aspect-[4/3] md:aspect-auto md:min-h-[300px]">
                                <div class="w-full h-full rounded-[1.8rem] overflow-hidden relative border border-white/[0.05] shadow-[inset_0_0_20px_rgba(0,0,0,0.8)]">
                                    {/* Image Overlay Gradient */}
                                    <div class="absolute inset-0 z-10 bg-gradient-to-t md:bg-gradient-to-r from-[#0c0c0e] via-[#0c0c0e]/80 md:via-transparent to-transparent opacity-80 group-hover:opacity-40 transition-opacity duration-700"></div>

                                    <img
                                        src={item.image}
                                        alt={item.name}
                                        class="w-full h-full object-cover transition-all duration-1000 ease-[cubic-bezier(0.19,1,0.22,1)] group-hover:scale-[1.05] origin-center filter brightness-90 group-hover:brightness-110"
                                    />

                                    {/* Schematic Grid Overlay */}
                                    <div class="absolute inset-0 bg-[linear-gradient(rgba(255,255,255,0.03)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,0.03)_1px,transparent_1px)] bg-[size:24px_24px] pointer-events-none mix-blend-overlay z-20"></div>

                                    {/* Hover Indicator Box */}
                                    <div class="absolute top-4 left-4 w-4 h-4 border border-white/20 z-20 group-hover:border-accent transition-colors duration-500">
                                        <div class="absolute inset-[3px] bg-accent/0 group-hover:bg-accent/40 transition-colors duration-500"></div>
                                    </div>
                                </div>
                            </div>

                            {/* Data Section - Right */}
                            <div class="w-full md:w-1/2 flex flex-col justify-between p-6 md:p-8 bg-gradient-to-b from-transparent to-[#08080a] md:border-l border-white/[0.03]">

                                <div>
                                    <div class="flex justify-between items-start mb-6">
                                        <span class="font-mono text-[9px] uppercase tracking-[0.2em] font-bold text-accent bg-accent/10 px-2.5 py-1 rounded border border-accent/20">
                                            {item.id}
                                        </span>
                                        <span class="font-mono text-[9px] text-foreground/40 tracking-[0.2em]">
                                            {item.era}
                                        </span>
                                    </div>

                                    <span class="block font-mono text-[10px] text-foreground/50 tracking-[0.2em] uppercase mb-2 font-bold flex items-center gap-2">
                                        <span class="w-1.5 h-1.5 bg-white/20 rounded-full group-hover:bg-accent transition-colors shadow-[0_0_8px_rgba(255,96,0,0)] group-hover:shadow-[0_0_8px_rgba(255,96,0,0.8)]"></span>
                                        {item.type}
                                    </span>

                                    <h3 class="font-serif text-3xl lg:text-4xl font-normal leading-tight tracking-tight text-white group-hover:text-accent transition-colors duration-500 mb-6">
                                        {item.name}
                                    </h3>
                                </div>

                                {/* Deep Specs */}
                                <div class="flex flex-col gap-3 pt-6 border-t border-white/[0.05] font-mono text-[9px] uppercase tracking-[0.15em]">
                                    <div class="flex justify-between items-center bg-white/[0.02] px-3 py-2 rounded">
                                        <span class="text-foreground/40 font-bold">Maker</span>
                                        <span class="text-white text-right font-semibold">{item.manufacturer}</span>
                                    </div>
                                    <div class="flex justify-between items-center bg-white/[0.02] px-3 py-2 rounded">
                                        <span class="text-foreground/40 font-bold">Engine</span>
                                        <span class="text-white text-right font-semibold">{item.synthesis}</span>
                                    </div>
                                    <div class="flex justify-between items-center bg-white/[0.02] px-3 py-2 rounded">
                                        <span class="text-foreground/40 font-bold">Filter</span>
                                        <span class="text-white text-right font-semibold">{item.filter}</span>
                                    </div>
                                </div>

                            </div>
                        </div>
                    </a>
                ))}
            </div>

            {/* Hardware Load More Trigger */}
            <div class="w-full flex justify-center mt-24 relative z-10">
                <button class="group/btn relative overflow-hidden bg-[#111] border border-white/10 rounded-2xl px-10 py-5 flex items-center gap-4 transition-all duration-300 hover:border-accent shadow-[0_10px_20px_rgba(0,0,0,0.5)] hover:shadow-[0_0_30px_rgba(255,96,0,0.2)] hover:-translate-y-1">
                    <div class="absolute inset-0 bg-gradient-to-b from-white/[0.05] to-transparent pointer-events-none"></div>
                    <span class="w-2 h-2 bg-accent rounded-full shadow-[0_0_8px_#ff6000] group-hover/btn:animate-ping"></span>
                    <span class="font-mono text-xs text-white uppercase tracking-[0.2em] font-bold">Scan Inventory</span>
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-foreground/50 group-hover/btn:text-accent transition-colors group-hover/btn:translate-y-1 duration-300"><line x1="12" y1="5" x2="12" y2="19"></line><polyline points="19 12 12 19 5 12"></polyline></svg>
                </button>
            </div>

        </main>

        <div class="relative z-10 w-full max-w-[1600px] mx-auto pb-8">
            <WaveformSection client:load />
        </div>
    </div>
</BaseLayout>
