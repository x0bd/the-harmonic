---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { WaveformSection } from "../../components/audio/WaveformSection";
import { releases } from "../../data/releases";
import { ReleaseHero } from "../../components/release/ReleaseHero";
import { TrackList } from "../../components/release/TrackList";
import type { Release } from "../../types/release";

export function getStaticPaths() {
    return releases.map((release: Release) => ({
        params: { slug: release.slug },
        props: { release },
    }));
}

const { release } = Astro.props;
---

<BaseLayout title={`${release.title} by ${release.artist} | The Harmonic`}>
    <div class="min-h-screen flex flex-col font-sans bg-background selection:bg-accent selection:text-white relative">
        <main class="relative z-10 w-full max-w-[1200px] mx-auto px-4 md:px-8 lg:px-12 pt-32 pb-40 flex-grow">
            
            <a href="/releases" class="inline-flex items-center gap-2 font-mono text-[10px] text-foreground/40 uppercase tracking-[0.2em] hover:text-white transition-colors mb-12">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg>
                Return to Vault
            </a>

            <ReleaseHero client:load release={release} />
            
            {release.description && (
                <article class="w-full max-w-3xl mt-12 mb-16">
                    <p class="font-serif text-xl md:text-2xl text-foreground/80 leading-relaxed">
                        {release.description}
                    </p>
                </article>
            )}

            <TrackList client:load tracks={release.tracks || []} />

        </main>
        
        <div class="relative z-10 w-full max-w-[1600px] mx-auto pb-8">
            <WaveformSection client:load />
        </div>
    </div>
</BaseLayout>
