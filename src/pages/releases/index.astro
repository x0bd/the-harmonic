---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { WaveformSection } from "../../components/audio/WaveformSection";

const releases = [
  {
    id: "RLS-042",
    artist: "Rrose",
    title: "Please Touch",
    label: "Eaux",
    year: "2023",
    genre: "Techno / Ambient",
    cover: "https://images.unsplash.com/photo-1618005182384-a83a8bd57fbe?q=80&w=800&auto=format&fit=crop",
    url: "#"
  },
  {
    id: "RLS-041",
    artist: "Boy Harsher",
    title: "Careful",
    label: "Nude Club",
    year: "2019",
    genre: "Darkwave",
    cover: "https://images.unsplash.com/photo-1574169208507-84376144848b?q=80&w=800&auto=format&fit=crop",
    url: "#"
  },
  {
    id: "RLS-040",
    artist: "Wata Igarashi",
    title: "WIP",
    label: "Kompakt",
    year: "2022",
    genre: "Deep Techno",
    cover: "https://images.unsplash.com/photo-1550684848-fac1c5b4e853?q=80&w=800&auto=format&fit=crop",
    url: "#"
  },
  {
    id: "RLS-039",
    artist: "Phase Fatale",
    title: "Scanning Backwards",
    label: "Ostgut Ton",
    year: "2020",
    genre: "Industrial",
    cover: "https://images.unsplash.com/photo-1508608226992-069a19c36829?q=80&w=800&auto=format&fit=crop",
    url: "#"
  },
  {
    id: "RLS-038",
    artist: "Alessandro Cortini",
    title: "Volume Massimo",
    label: "Mute",
    year: "2019",
    genre: "Experimental",
    cover: "https://images.unsplash.com/photo-1598387181032-a3103a2db5b3?q=80&w=800&auto=format&fit=crop",
    url: "#"
  },
  {
    id: "RLS-037",
    artist: "Lebanon Hanover",
    title: "Tomb for Two",
    label: "Fabrika",
    year: "2013",
    genre: "Coldwave",
    cover: "https://images.unsplash.com/photo-1520166986518-18e3ab039324?q=80&w=800&auto=format&fit=crop",
    url: "#"
  }
];
---

<BaseLayout title="Releases | The Harmonic">
    <div class="min-h-screen flex flex-col font-sans bg-background selection:bg-accent selection:text-white relative">

        <main class="relative z-10 w-full max-w-[1600px] mx-auto px-4 md:px-8 lg:px-12 pt-40 pb-40 overflow-hidden flex-grow">

            {/* Aggressive Hardware Header */}
            <header class="w-full mb-20 relative">
                {/* Background Track */}
                <div class="absolute top-1/2 left-0 w-full h-[1px] bg-white/5 -translate-y-1/2 -z-10 hidden md:block"></div>

                <div class="inline-block bg-background pr-8 relative z-10">
                    <div class="flex items-center gap-3 mb-4">
                        <div class="w-2 h-2 bg-accent rounded-sm shadow-[0_0_12px_#ff6000] rotate-45"></div>
                        <span class="font-mono text-[10px] text-foreground/40 uppercase tracking-[0.3em] font-bold">Directory // 03</span>
                    </div>
                    <h1 class="font-serif text-6xl md:text-8xl lg:text-[7rem] tracking-tighter text-white leading-none drop-shadow-lg">
                        Sonic <span class="text-accent italic">&</span> <br class="hidden md:block" /> Releases
                    </h1>
                </div>
            </header>

            {/* Hardware Filter / Status Bar */}
            <div class="flex flex-col md:flex-row justify-between items-start md:items-end gap-8 mb-16 relative bg-[#0c0c0e] p-6 md:p-8 rounded-[2rem] border border-white/[0.05] shadow-[0_20px_40px_rgba(0,0,0,0.4),inset_0_1px_1px_rgba(255,255,255,0.05)]">

                <div class="flex flex-wrap gap-3 font-mono text-[10px] tracking-[0.2em] uppercase font-bold">
                    <button class="bg-accent text-black px-6 py-3 rounded-xl shadow-[0_0_15px_rgba(255,96,0,0.3),inset_0_2px_4px_rgba(255,255,255,0.4)] transition-all">
                        Latest
                    </button>
                    <button class="bg-[#151515] text-foreground/50 border border-white/10 px-6 py-3 rounded-xl hover:bg-white/5 hover:text-white transition-all shadow-[inset_0_2px_4px_rgba(0,0,0,0.5)]">
                        Albums
                    </button>
                    <button class="bg-[#151515] text-foreground/50 border border-white/10 px-6 py-3 rounded-xl hover:bg-white/5 hover:text-white transition-all shadow-[inset_0_2px_4px_rgba(0,0,0,0.5)]">
                        EPs
                    </button>
                    <button class="bg-[#151515] text-foreground/50 border border-white/10 px-6 py-3 rounded-xl hover:bg-white/5 hover:text-white transition-all shadow-[inset_0_2px_4px_rgba(0,0,0,0.5)]">
                        Compilations
                    </button>
                </div>

                {/* Technical Readout */}
                <div class="flex flex-col items-end gap-2 font-mono text-[9px] text-foreground/40 tracking-[0.25em] uppercase">
                    <div class="flex items-center gap-3">
                        <span>Display: Vault</span>
                        <div class="flex gap-1 flex-wrap w-4 h-4">
                            <span class="w-1.5 h-1.5 bg-accent shadow-[0_0_8px_#ff6000]"></span>
                            <span class="w-1.5 h-1.5 bg-white/20"></span>
                            <span class="w-1.5 h-1.5 bg-white/20"></span>
                            <span class="w-1.5 h-1.5 bg-white/20"></span>
                        </div>
                    </div>
                    <span>Signals_Found: {releases.length < 10 ? `0${releases.length}` : releases.length}</span>
                </div>
            </div>

            {/* The Vault Grid */}
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6 lg:gap-8 relative z-10">
                {releases.map((release) => (
                    <a href={release.url} class="group relative flex flex-col transition-all duration-700 rounded-[2rem] overflow-hidden bg-[#0c0c0e] border border-white/[0.04] hover:border-accent/40 shadow-[0_20px_40px_rgba(0,0,0,0.6)] hover:shadow-[0_0_60px_rgba(255,96,0,0.15)] hover:-translate-y-2">
                        {/* High-end hardware inner bezel */}
                        <div class="absolute inset-0 z-0 pointer-events-none rounded-[inherit] shadow-[inset_0_2px_2px_rgba(255,255,255,0.06),inset_0_-1px_1px_rgba(0,0,0,0.5)]"></div>

                        {/* Record Sleeve / Image */}
                        <div class="w-full relative bg-[#030303] aspect-square p-3">
                            <div class="w-full h-full rounded-[1.5rem] overflow-hidden relative border border-white/[0.05] shadow-[inset_0_0_20px_rgba(0,0,0,0.8)]">
                                {/* Image Overlay Gradient */}
                                <div class="absolute inset-0 z-10 bg-gradient-to-t from-[#0c0c0e] via-transparent to-transparent opacity-60 group-hover:opacity-20 transition-opacity duration-700"></div>

                                <img
                                    src={release.cover}
                                    alt={release.title}
                                    class="w-full h-full object-cover transition-all duration-1000 ease-[cubic-bezier(0.19,1,0.22,1)] group-hover:scale-[1.05] group-hover:rotate-1 origin-center filter brightness-90 group-hover:brightness-110"
                                />

                                {/* Vinyl Groove overlay hint */}
                                <div class="absolute inset-0 rounded-[1.5rem] shadow-[inset_0_0_0_1px_rgba(255,255,255,0.05)] z-20 pointer-events-none border border-white/5"></div>

                                {/* Play icon overlay on hover */}
                                <div class="absolute inset-0 flex items-center justify-center z-30 opacity-0 group-hover:opacity-100 transition-all duration-500 scale-90 group-hover:scale-100">
                                    <div class="w-16 h-16 rounded-full bg-black/60 backdrop-blur-md border border-accent flex items-center justify-center shadow-[0_0_30px_rgba(255,96,0,0.5)]">
                                        <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor" class="text-accent ml-1"><path d="M8 5v14l11-7z" /></svg>
                                    </div>
                                </div>
                            </div>
                        </div>

                        {/* Release Info */}
                        <div class="relative z-10 flex flex-col flex-grow p-6 md:p-8">

                            <div class="flex justify-between items-start mb-4">
                                <span class="font-mono text-[9px] uppercase tracking-[0.2em] font-bold text-accent bg-accent/10 px-2.5 py-1 rounded border border-accent/20">
                                    {release.id}
                                </span>
                                <span class="font-mono text-[9px] text-foreground/40 tracking-[0.2em]">
                                    {release.year}
                                </span>
                            </div>

                            <h3 class="font-serif text-2xl lg:text-3xl font-normal leading-tight tracking-tight text-white group-hover:text-accent transition-colors duration-500 mb-1 line-clamp-2">
                                {release.title}
                            </h3>

                            <h4 class="font-sans text-sm font-semibold text-foreground/60 mb-6">
                                {release.artist}
                            </h4>

                            <div class="mt-auto flex flex-col gap-3 pt-6 border-t border-white/[0.05]">
                                <div class="flex justify-between items-center font-mono text-[9px] uppercase tracking-[0.2em]">
                                    <span class="text-foreground/40 font-bold">Label</span>
                                    <span class="text-white text-right">{release.label}</span>
                                </div>
                                <div class="flex justify-between items-center font-mono text-[9px] uppercase tracking-[0.2em]">
                                    <span class="text-foreground/40 font-bold">Genre</span>
                                    <span class="text-white text-right truncate pl-4">{release.genre}</span>
                                </div>
                            </div>
                        </div>
                    </a>
                ))}
            </div>

            {/* Hardware Load More Trigger */}
            <div class="w-full flex justify-center mt-24 relative z-10">
                <button class="group/btn relative overflow-hidden bg-[#111] border border-white/10 rounded-2xl px-10 py-5 flex items-center gap-4 transition-all duration-300 hover:border-accent shadow-[0_10px_20px_rgba(0,0,0,0.5)] hover:shadow-[0_0_30px_rgba(255,96,0,0.2)] hover:-translate-y-1">
                    <div class="absolute inset-0 bg-gradient-to-b from-white/[0.05] to-transparent pointer-events-none"></div>
                    <span class="w-2 h-2 bg-accent rounded-full shadow-[0_0_8px_#ff6000] group-hover/btn:animate-ping"></span>
                    <span class="font-mono text-xs text-white uppercase tracking-[0.2em] font-bold">Access Deep Storage</span>
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-foreground/50 group-hover/btn:text-accent transition-colors group-hover/btn:translate-y-1 duration-300"><line x1="12" y1="5" x2="12" y2="19"></line><polyline points="19 12 12 19 5 12"></polyline></svg>
                </button>
            </div>

        </main>

        <div class="relative z-10 w-full max-w-[1600px] mx-auto pb-8">
            <WaveformSection client:load />
        </div>
    </div>
</BaseLayout>
