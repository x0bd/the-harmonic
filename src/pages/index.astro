---
import BaseLayout from "../layouts/BaseLayout.astro";
import {
    ArticleCard,
    CardMeta,
    CardTag,
    CardImage,
    CardTitle,
    CardExcerpt,
    CardDataPoints,
} from "../components/article/ArticleCard";
import { WaveformSection } from "../components/audio/WaveformSection";
---

<BaseLayout>
    <div class="p-4 min-h-screen flex flex-col pt-16 font-sans">
        {/* Negative Space Player Hero */}
        <header
            class="relative h-[calc(100vh-2rem)] w-full bg-[#030303] overflow-hidden flex flex-col justify-between p-8 md:p-12 border-b border-[#ffffff1a] cursor-crosshair"
        >
            {
                /* Grid Background overlay for tech feel. Center remains empty for future shader. */
            }
            <div
                class="absolute inset-0 bg-[linear-gradient(rgba(255,255,255,0.02)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,0.02)_1px,transparent_1px)] bg-[size:40px_40px] pointer-events-none opacity-50 z-0"
            >
            </div>

            {/* Top Bar - Pushed to edges */}
            <div class="relative z-10 w-full flex justify-between items-start">
                <div class="flex flex-col gap-1">
                    <span
                        class="font-mono text-[10px] text-[#88888D] tracking-[0.3em] uppercase"
                        >SYS.OP</span
                    >
                    <span
                        class="font-sans text-sm font-bold tracking-widest text-white"
                        >THE HARMONIC</span
                    >
                </div>
                <div class="flex flex-col items-end gap-1 text-right">
                    <span
                        class="font-mono text-[10px] text-[#88888D] tracking-[0.3em] uppercase"
                        >STATUS</span
                    >
                    <span
                        class="font-mono text-[10px] text-[#7b61ff] tracking-[0.2em] font-bold"
                        >RESONATING</span
                    >
                </div>
            </div>

            {/* Huge Empty Center for the Shader */}
            <div class="flex-grow"></div>

            {/* Bottom Bar - Player Controls & Track Info */}
            <div
                class="relative z-10 w-full flex flex-col md:flex-row justify-between items-end gap-8"
            >
                {/* Left: Track Info (Massive Typography) */}
                <div class="flex flex-col">
                    <div
                        class="font-mono text-[10px] text-[#7b61ff] tracking-[0.3em] uppercase mb-4 font-bold flex items-center gap-3"
                    >
                        <span
                            class="w-2 h-2 bg-[#7b61ff] rounded-full animate-pulse shadow-[0_0_8px_#7b61ff]"
                        ></span>
                        NOW PLAYING
                    </div>
                    <h1
                        class="font-sans text-[clamp(3.5rem,8vw,8rem)] font-black leading-[0.85] text-white tracking-tighter uppercase mix-blend-screen drop-shadow-[0_0_15px_rgba(255,255,255,0.2)]"
                    >
                        Careful<br />
                        <span
                            class="text-transparent bg-clip-text bg-gradient-to-b from-white to-[#4a4d58]"
                            >Boy Harsher</span
                        >
                    </h1>
                </div>

                {/* Right: Player Controls & Readouts */}
                <div class="flex flex-col items-end gap-6 w-full md:w-auto">
                    <div
                        class="flex items-end gap-8 w-full justify-between md:justify-end border-b border-[#ffffff1a] pb-4"
                    >
                        <div class="flex flex-col">
                            <span
                                class="font-mono text-[9px] text-[#88888D] tracking-[0.2em] uppercase"
                                >TIME</span
                            >
                            <span class="font-mono text-sm text-white"
                                >03:14</span
                            >
                        </div>
                        <div class="flex flex-col text-right">
                            <span
                                class="font-mono text-[9px] text-[#88888D] tracking-[0.2em] uppercase"
                                >REMAINING</span
                            >
                            <span class="font-mono text-sm text-[#4a4d58]"
                                >-01:42</span
                            >
                        </div>
                    </div>

                    <div class="flex items-center gap-8">
                        <button
                            class="text-[#88888D] hover:text-white transition-colors"
                            aria-label="Previous"
                        >
                            <svg
                                width="24"
                                height="24"
                                viewBox="0 0 24 24"
                                fill="currentColor"
                                ><path d="M6 6h2v12H6zm3.5 6l8.5 6V6z"
                                ></path></svg
                            >
                        </button>
                        <button
                            class="w-16 h-16 rounded-full border border-white/20 flex items-center justify-center text-white hover:bg-white hover:text-black transition-all shadow-[0_0_15px_rgba(255,255,255,0.1)] hover:shadow-[0_0_25px_rgba(255,255,255,0.5)]"
                            aria-label="Play"
                        >
                            <svg
                                width="24"
                                height="24"
                                viewBox="0 0 24 24"
                                fill="currentColor"
                                class="ml-1"
                                ><path d="M8 5v14l11-7z"></path></svg
                            >
                        </button>
                        <button
                            class="text-[#88888D] hover:text-white transition-colors"
                            aria-label="Next"
                        >
                            <svg
                                width="24"
                                height="24"
                                viewBox="0 0 24 24"
                                fill="currentColor"
                                ><path d="M6 18l8.5-6L6 6v12zM16 6v12h2V6h-2z"
                                ></path></svg
                            >
                        </button>
                    </div>
                </div>
            </div>
        </header>

        {/* Editorial Section - Staggered Grid */}
        <main
            class="relative z-10 bg-[#030303] max-w-7xl mx-auto w-full px-4 md:px-16 pt-32 pb-64"
        >
            <div
                class="flex flex-col md:flex-row md:items-end justify-between mb-24 border-b-2 border-white/20 pb-8 gap-4"
            >
                <h2
                    class="font-sans text-4xl md:text-6xl font-black text-white tracking-tighter uppercase"
                >
                    Distorted<br /><span class="text-[#88888D]">Signals</span>
                </h2>
                <div
                    class="font-mono text-xs text-[#7b61ff] uppercase tracking-[0.2em] font-bold"
                >
                    [ RECORDING.001 - 004 ]
                </div>
            </div>

            <div
                class="grid grid-cols-1 md:grid-cols-12 gap-x-12 gap-y-32 md:gap-y-0"
            >
                {/* Item 1 - Boy Harsher */}
                <div class="md:col-start-1 md:col-end-8">
                    <ArticleCard>
                        <CardImage
                            aspectRatio="aspect-[16/9]"
                            src="https://images.unsplash.com/photo-1574169208507-84376144848b?q=80&w=2000&auto=format&fit=crop"
                            alt="Harsh lighting in a concrete room"
                        />
                        <CardMeta>
                            <span
                                class="text-[#7b61ff] font-bold tracking-widest"
                                >ARTIST PROFILE</span
                            >
                            <span class="text-white">VOL.01</span>
                        </CardMeta>
                        <CardTitle
                            className="text-5xl font-black uppercase tracking-tighter mt-2"
                            >Boy Harsher</CardTitle
                        >
                        <CardExcerpt className="mt-4 text-base">
                            The relentless pulse of modern darkwave. Exploring
                            the sweaty, desperate synthesis of 'Careful' and how
                            they weaponize the Roland SH-101 to build cinematic
                            dread in the club.
                        </CardExcerpt>
                        <CardDataPoints
                            data={[
                                { label: "GENRE", value: "DARKWAVE" },
                                { label: "LOC", value: "SAVANNAH, GA" },
                                { label: "SYS.ID", value: "SH-101 / TR-505" },
                            ]}
                        />
                    </ArticleCard>
                </div>

                {/* Item 2 - Yeah Yeah Yeahs */}
                <div class="md:col-start-9 md:col-end-13 md:mt-48">
                    <ArticleCard>
                        <CardImage
                            aspectRatio="aspect-[3/4]"
                            src="https://images.unsplash.com/photo-1520166986518-18e3ab039324?q=80&w=2000&auto=format&fit=crop"
                            alt="Distorted amplifier"
                        />
                        <CardMeta>
                            <span
                                class="text-[#7b61ff] font-bold tracking-widest"
                                >RETROSPECTIVE</span
                            >
                            <span class="text-white">VOL.02</span>
                        </CardMeta>
                        <CardTitle
                            className="text-4xl font-black uppercase tracking-tighter mt-2"
                            >Yeah Yeah Yeahs</CardTitle
                        >
                        <CardExcerpt className="mt-4 text-base">
                            Fever to Tell. The raw, unpolished energy of early
                            2000s New York post-punk revival. Deconstructing the
                            jagged guitar tones and Karen O's visceral vocal
                            delivery that defined an era of grit.
                        </CardExcerpt>
                        <CardDataPoints
                            data={[
                                { label: "ERA", value: "2003" },
                                { label: "STYLE", value: "POST-PUNK" },
                            ]}
                        />
                    </ArticleCard>
                </div>

                {/* Item 3 - Lebanon Hanover */}
                <div class="md:col-start-2 md:col-end-7 md:mt-80">
                    <ArticleCard>
                        <CardImage
                            aspectRatio="aspect-[4/5]"
                            src="https://images.unsplash.com/photo-1508608226992-069a19c36829?q=80&w=2000&auto=format&fit=crop"
                            alt="Desolate urban landscape"
                        />
                        <CardMeta>
                            <span
                                class="text-[#7b61ff] font-bold tracking-widest"
                                >SCENE REPORT</span
                            >
                            <span class="text-white">VOL.03</span>
                        </CardMeta>
                        <CardTitle
                            className="text-4xl font-black uppercase tracking-tighter mt-2"
                            >Lebanon Hanover</CardTitle
                        >
                        <CardExcerpt className="mt-4 text-base">
                            Minimalist coldwave and the aesthetics of isolation.
                            Analyzing the stark, algorithmic basslines and
                            deadpan dual vocals that soundtrack the modern
                            romanticized decay.
                        </CardExcerpt>
                        <CardDataPoints
                            data={[
                                { label: "VIBE", value: "COLDWAVE" },
                                { label: "BPM", value: "115" },
                            ]}
                        />
                    </ArticleCard>
                </div>

                {/* Item 4 - Nine Inch Nails */}
                <div class="md:col-start-8 md:col-end-13 md:mt-24">
                    <ArticleCard>
                        <CardImage
                            aspectRatio="aspect-[16/9]"
                            src="https://images.unsplash.com/photo-1598387181032-a3103a2db5b3?q=80&w=2000&auto=format&fit=crop"
                            alt="Rack mounted hardware gear"
                        />
                        <CardMeta>
                            <span
                                class="text-[#7b61ff] font-bold tracking-widest"
                                >DEEP DIVE</span
                            >
                            <span class="text-white">VOL.04</span>
                        </CardMeta>
                        <CardTitle
                            className="text-5xl font-black uppercase tracking-tighter mt-2"
                            >Nine Inch Nails</CardTitle
                        >
                        <CardExcerpt className="mt-4 text-base">
                            The Downward Spiral and the mechanization of angst.
                            How Trent Reznor merged the agonizing brutality of
                            industrial metal with pop sensibilities, reshaping
                            the landscape of heavy electronic music forever.
                        </CardExcerpt>
                        <CardDataPoints
                            data={[
                                { label: "FOCUS", value: "INDUSTRIAL" },
                                { label: "ALBUM", value: "1994" },
                                { label: "SYS.ID", value: "PROPHET-5" },
                            ]}
                        />
                    </ArticleCard>
                </div>
            </div>
        </main>

        <WaveformSection client:load />
    </div>
</BaseLayout>
