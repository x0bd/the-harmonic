---
import BaseLayout from "../layouts/BaseLayout.astro";
import {
    ArticleCard,
    CardMeta,
    CardTag,
    CardImage,
    CardTitle,
    CardExcerpt,
    CardDataPoints,
} from "../components/article/ArticleCard";
import { WaveformSection } from "../components/audio/WaveformSection";
---

<BaseLayout>
    <div class="p-4 min-h-screen flex flex-col pt-16 font-sans">
        {/* Monolith Hero Section */}
        <header
            class="relative h-[calc(100vh-2rem)] w-full bg-[#030303] overflow-hidden flex flex-col items-center justify-center"
        >
            <div class="relative z-10 flex flex-col items-center">
                {/* Vertical Credits */}
                <div class="absolute flex flex-col items-center gap-8 -top-32">
                    <div class="flex flex-col items-center gap-1.5">
                        <span
                            class="font-mono text-[9px] text-[#88888D] tracking-[0.2em] uppercase"
                            >Visual by</span
                        >
                        <span
                            class="font-sans text-[10px] tracking-[0.1em] text-white"
                            >SYS.OP</span
                        >
                    </div>
                    <div class="flex flex-col items-center gap-1.5">
                        <span
                            class="font-mono text-[9px] text-[#88888D] tracking-[0.2em] uppercase"
                            >Audio by</span
                        >
                        <span
                            class="font-sans text-[10px] tracking-[0.1em] text-white"
                            >RESONATOR</span
                        >
                    </div>
                </div>

                {/* Monolith Container */}
                <div
                    class="relative w-[80vw] lg:w-[40vw] max-w-[500px] aspect-square flex items-center justify-center bg-black/20 backdrop-blur-sm border-2 border-white/90 z-[2] transition-shadow duration-1000 shadow-[0_0_15px_rgba(255,255,255,0.6),_0_0_30px_rgba(255,255,255,0.3),_inset_0_0_10px_rgba(255,255,255,0.2)] hover:shadow-[0_0_20px_rgba(255,255,255,0.9),_0_0_50px_rgba(255,255,255,0.5),_inset_0_0_15px_rgba(255,255,255,0.4)] group cursor-crosshair"
                >
                    <h1
                        class="font-sans text-[clamp(3rem,6vw,6rem)] font-light leading-none text-center mix-blend-screen flex flex-col items-center text-white drop-shadow-[0_0_20px_rgba(255,255,255,0.3)]"
                    >
                        <span class="font-bold tracking-tight">ECHOES</span>
                        <span
                            class="italic font-light text-3xl md:text-5xl mt-2 text-[#E4E4E6]"
                            >of the Void</span
                        >
                    </h1>
                </div>
            </div>

            {/* Simulated Water Plane / Reflection Area */}
            <div
                class="absolute bottom-0 left-0 w-full h-[30vh] bg-gradient-to-t from-[#030303] to-transparent z-[1] overflow-hidden flex justify-center opacity-40 blur-md"
            >
                <div
                    class="relative top-[-30vh] w-[80vw] lg:w-[40vw] max-w-[500px] aspect-square border-2 border-white shadow-[0_0_15px_rgba(255,255,255,0.6)] origin-bottom scale-y-[-1] blur-[8px]"
                    style={{
                        maskImage:
                            "linear-gradient(to bottom, transparent 20%, black 100%)",
                        WebkitMaskImage:
                            "linear-gradient(to bottom, transparent 20%, black 100%)",
                    }}
                >
                </div>
            </div>
        </header>

        {/* Editorial Section - Staggered Grid */}
        <main
            class="relative z-10 bg-[#030303] max-w-7xl mx-auto w-full px-4 md:px-16 pt-32 pb-64"
        >
            <div
                class="flex items-center justify-between mb-16 border-b border-[#ffffff1a] pb-6"
            >
                <h2
                    class="font-sans text-2xl md:text-3xl font-light text-white"
                >
                    Latest Transmissions
                </h2>
                <div
                    class="font-mono text-[0.65rem] text-[#88888D] uppercase tracking-[0.1em]"
                >
                    INDEX / 001 - 004
                </div>
            </div>

            <div
                class="grid grid-cols-1 md:grid-cols-12 gap-x-8 gap-y-24 md:gap-y-0"
            >
                {/* Item 1 */}
                <div class="md:col-start-2 md:col-end-8">
                    <ArticleCard>
                        <CardImage
                            aspectRatio="aspect-[16/9]"
                            src="https://images.unsplash.com/photo-1614613535308-eb5fbd3d2c17?q=80&w=2000&auto=format&fit=crop"
                            alt="Synthesizer setup in dark studio"
                        />
                        <CardMeta>
                            <span>Interview / Tokyo</span>
                            <span class="text-white">08.24</span>
                        </CardMeta>
                        <CardTitle>The Architecture of Noise</CardTitle>
                        <CardExcerpt>
                            Exploring the brutalist sonic landscapes constructed
                            by algorithmic composers utilizing extreme
                            frequencies.
                        </CardExcerpt>
                        <CardDataPoints
                            data={[
                                { label: "BPM RANGE", value: "0 - 240" },
                                { label: "DURATION", value: "14 MIN" },
                                { label: "SYS.ID", value: "TX-81Z" },
                            ]}
                        />
                    </ArticleCard>
                </div>

                {/* Item 2 */}
                <div class="md:col-start-9 md:col-end-13 md:mt-32">
                    <ArticleCard>
                        <CardImage
                            aspectRatio="aspect-[4/5]"
                            src="https://images.unsplash.com/photo-1510212351786-bb2d7cc0b5bb?q=80&w=2000&auto=format&fit=crop"
                            alt="Abstract dark geometric interior"
                        />
                        <CardMeta>
                            <span>Exhibition / Berlin</span>
                            <span class="text-white">07.24</span>
                        </CardMeta>
                        <CardTitle>Negative Space as Instrumentation</CardTitle>
                        <CardExcerpt>
                            How silence and sub-bass create physical tension in
                            warehouse environments. A study of acoustic shadows.
                        </CardExcerpt>
                        <CardDataPoints
                            data={[
                                { label: "FOCUS", value: "Acoustics" },
                                { label: "SYS.ID", value: "SP-1200" },
                            ]}
                        />
                    </ArticleCard>
                </div>

                {/* Item 3 */}
                <div class="md:col-start-1 md:col-end-6 md:mt-64">
                    <ArticleCard>
                        <CardImage
                            aspectRatio="aspect-[16/9]"
                            src="https://images.unsplash.com/photo-1550684848-fac1c5b4e853?q=80&w=2000&auto=format&fit=crop"
                            alt="Circuit board macro"
                        />
                        <CardMeta>
                            <span>Hardware / Review</span>
                            <span class="text-white">06.24</span>
                        </CardMeta>
                        <CardTitle>Crystalline Synthesis</CardTitle>
                        <CardExcerpt>
                            Deconstructing the spectral oscillators and
                            wavetable manipulation of the latest modular rigs.
                        </CardExcerpt>
                        <CardDataPoints
                            data={[{ label: "TECH", value: "Eurorack" }]}
                        />
                    </ArticleCard>
                </div>

                {/* Item 4 */}
                <div class="md:col-start-7 md:col-end-12 md:mt-16">
                    <ArticleCard>
                        <CardImage
                            aspectRatio="aspect-[4/5]"
                            src="https://images.unsplash.com/photo-1493225457124-a1a2a5fafe3f?q=80&w=2000&auto=format&fit=crop"
                            alt="Person standing in dark smoke"
                        />
                        <CardMeta>
                            <span>Culture / Underground</span>
                            <span class="text-white">05.24</span>
                        </CardMeta>
                        <CardTitle>The Wabi-Sabi of Tape Hiss</CardTitle>
                        <CardExcerpt>
                            Finding perfection in degradation. Why ambient
                            artists are returning to magnetic tape to humanize
                            digital clinicality.
                        </CardExcerpt>
                        <CardDataPoints
                            data={[
                                { label: "MEDIUM", value: "Cassette" },
                                { label: "SYS.ID", value: "RE-201" },
                            ]}
                        />
                    </ArticleCard>
                </div>
            </div>
        </main>

        <WaveformSection client:load />
    </div>
</BaseLayout>
