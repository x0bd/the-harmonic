---
import BaseLayout from "../layouts/BaseLayout.astro";
import { Hero } from "../components/layout/Hero";
import {
    ArticleCard,
    CardMeta,
    CardTag,
    CardImage,
    CardTitle,
    CardExcerpt,
    CardDataPoints,
} from "../components/article/ArticleCard";
import { WaveformSection } from "../components/audio/WaveformSection";
---

<BaseLayout>
    <div class="min-h-screen flex flex-col font-sans">
        {/* Negative Space Hero */}
        <Hero client:load />

        {/* Editorial Section - Brutalist Staggered Grid */}
        <main
            class="relative z-10 bg-[#030303] max-w-[1400px] mx-auto w-full px-4 md:px-16 pt-32 pb-64 overflow-hidden"
        >
            {/* Massive Structural Guide Lines */}
            <div
                class="absolute top-0 bottom-0 left-1/2 w-[1px] bg-white/[0.03] pointer-events-none z-0"
            >
            </div>

            {/* Brutalist Section Header */}
            <div
                class="relative w-full mb-48 pt-16 flex flex-col items-center justify-center border-b border-dashed border-white/20 pb-24"
            >
                <h2
                    class="font-sans text-[clamp(4rem,15vw,14rem)] font-black leading-[0.75] tracking-tighter uppercase text-white/[0.03] absolute top-8 left-0 w-full text-center select-none pointer-events-none"
                >
                    DISTORTED
                </h2>
                <h2
                    class="font-sans text-[clamp(4rem,15vw,14rem)] font-black leading-[0.75] tracking-tighter uppercase text-transparent select-none z-10"
                    style={{ WebkitTextStroke: "1px rgba(255,255,255,0.8)" }}
                >
                    SIGNALS
                </h2>
                <div
                    class="absolute bottom-4 right-4 font-mono text-[10px] text-[#7b61ff] tracking-[0.3em] uppercase bg-[#030303] px-4 py-2 border border-white/10"
                >
                    [ INDEX / 001 - 004 ]
                </div>
            </div>

            <div
                class="grid grid-cols-1 md:grid-cols-12 gap-x-12 gap-y-48 md:gap-y-0 relative z-10"
            >
                {/* Item 1 - Boy Harsher */}
                <div class="md:col-start-1 md:col-end-8 relative">
                    <ArticleCard indexStr="01">
                        <CardImage
                            aspectRatio="aspect-[16/9]"
                            src="https://images.unsplash.com/photo-1574169208507-84376144848b?q=80&w=2000&auto=format&fit=crop"
                            alt="Harsh lighting in a concrete room"
                        />
                        <CardMeta>
                            <span
                                class="text-[#7b61ff] font-bold tracking-widest"
                                >ARTIST PROFILE</span
                            >
                            <span class="text-white bg-white/10 px-2 py-1"
                                >VOL.01</span
                            >
                        </CardMeta>
                        <CardTitle
                            className="text-5xl md:text-7xl font-black uppercase tracking-tighter mt-2"
                            >Boy Harsher</CardTitle
                        >
                        <CardExcerpt
                            className="mt-4 text-base md:text-lg max-w-xl"
                        >
                            The relentless pulse of modern darkwave. Exploring
                            the sweaty, desperate synthesis of 'Careful' and how
                            they weaponize the Roland SH-101 to build cinematic
                            dread in the club.
                        </CardExcerpt>
                        <CardDataPoints
                            data={[
                                { label: "GENRE", value: "DARKWAVE" },
                                { label: "LOC", value: "SAVANNAH, GA" },
                                { label: "SYS.ID", value: "SH-101 / TR-505" },
                            ]}
                        />
                    </ArticleCard>
                </div>

                {/* Item 2 - Yeah Yeah Yeahs */}
                <div class="md:col-start-8 md:col-end-13 md:mt-64 relative">
                    <ArticleCard indexStr="02">
                        <CardImage
                            aspectRatio="aspect-[3/4]"
                            src="https://images.unsplash.com/photo-1520166986518-18e3ab039324?q=80&w=2000&auto=format&fit=crop"
                            alt="Distorted amplifier"
                        />
                        <CardMeta>
                            <span
                                class="text-[#7b61ff] font-bold tracking-widest"
                                >RETROSPECTIVE</span
                            >
                            <span class="text-white bg-white/10 px-2 py-1"
                                >VOL.02</span
                            >
                        </CardMeta>
                        <CardTitle
                            className="text-4xl md:text-6xl font-black uppercase tracking-tighter mt-2"
                            >Yeah Yeah<br />Yeahs</CardTitle
                        >
                        <CardExcerpt
                            className="mt-4 text-base md:text-lg max-w-sm"
                        >
                            Fever to Tell. The raw, unpolished energy of early
                            2000s New York post-punk revival. Deconstructing the
                            jagged guitar tones and visceral vocal delivery that
                            defined an era of grit.
                        </CardExcerpt>
                        <CardDataPoints
                            data={[
                                { label: "ERA", value: "2003" },
                                { label: "STYLE", value: "POST-PUNK" },
                            ]}
                        />
                    </ArticleCard>
                </div>

                {/* Item 3 - Lebanon Hanover */}
                <div class="md:col-start-2 md:col-end-7 md:mt-[32rem] relative">
                    <ArticleCard indexStr="03">
                        <CardImage
                            aspectRatio="aspect-[4/5]"
                            src="https://images.unsplash.com/photo-1508608226992-069a19c36829?q=80&w=2000&auto=format&fit=crop"
                            alt="Desolate urban landscape"
                        />
                        <CardMeta>
                            <span
                                class="text-[#7b61ff] font-bold tracking-widest"
                                >SCENE REPORT</span
                            >
                            <span class="text-white bg-white/10 px-2 py-1"
                                >VOL.03</span
                            >
                        </CardMeta>
                        <CardTitle
                            className="text-4xl md:text-6xl font-black uppercase tracking-tighter mt-2"
                            >Lebanon<br />Hanover</CardTitle
                        >
                        <CardExcerpt
                            className="mt-4 text-base md:text-lg max-w-md"
                        >
                            Minimalist coldwave and the aesthetics of isolation.
                            Analyzing the stark, algorithmic basslines and
                            deadpan dual vocals that soundtrack the modern
                            romanticized decay.
                        </CardExcerpt>
                        <CardDataPoints
                            data={[
                                { label: "VIBE", value: "COLDWAVE" },
                                { label: "BPM", value: "115" },
                            ]}
                        />
                    </ArticleCard>
                </div>

                {/* Item 4 - Nine Inch Nails */}
                <div class="md:col-start-6 md:col-end-13 md:mt-32 relative">
                    <ArticleCard indexStr="04">
                        <CardImage
                            aspectRatio="aspect-[16/9]"
                            src="https://images.unsplash.com/photo-1598387181032-a3103a2db5b3?q=80&w=2000&auto=format&fit=crop"
                            alt="Rack mounted hardware gear"
                        />
                        <CardMeta>
                            <span
                                class="text-[#7b61ff] font-bold tracking-widest"
                                >DEEP DIVE</span
                            >
                            <span class="text-white bg-white/10 px-2 py-1"
                                >VOL.04</span
                            >
                        </CardMeta>
                        <CardTitle
                            className="text-5xl md:text-8xl font-black uppercase tracking-tighter mt-2"
                            >Nine Inch<br />Nails</CardTitle
                        >
                        <CardExcerpt
                            className="mt-4 text-base md:text-lg max-w-2xl"
                        >
                            The Downward Spiral and the mechanization of angst.
                            How Trent Reznor merged the agonizing brutality of
                            industrial metal with pop sensibilities, reshaping
                            the landscape of heavy electronic music forever.
                        </CardExcerpt>
                        <CardDataPoints
                            data={[
                                { label: "FOCUS", value: "INDUSTRIAL" },
                                { label: "ALBUM", value: "1994" },
                                { label: "SYS.ID", value: "PROPHET-5" },
                            ]}
                        />
                    </ArticleCard>
                </div>
            </div>
        </main>

        <WaveformSection client:load />
    </div>
</BaseLayout>
