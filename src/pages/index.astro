---
import BaseLayout from "../layouts/BaseLayout.astro";
import { Hero } from "../components/layout/Hero";
import {
    ArticleCard,
    CardMeta,
    CardTag,
    CardImage,
    CardTitle,
    CardExcerpt,
    CardDataPoints,
} from "../components/article/ArticleCard";
import { WaveformSection } from "../components/audio/WaveformSection";
---

<BaseLayout>
    <div class="min-h-screen flex flex-col font-sans bg-background selection:bg-accent selection:text-white">
        <Hero client:load />

        <main class="relative z-10 max-w-[1400px] mx-auto w-full px-6 md:px-12 pt-24 pb-32">
            <div class="flex items-end justify-between mb-16 border-b border-white/10 pb-6">
                <div>
                    <h2 class="font-serif text-4xl md:text-5xl font-normal text-white mb-2">Latest Transmissions</h2>
                    <p class="font-sans text-foreground/60">Curated essays and hardware analyses.</p>
                </div>
                <a href="/essays" class="hidden md:inline-flex items-center gap-2 font-sans font-semibold text-sm text-accent hover:text-white transition-colors">
                    View Archive
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
                </a>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                {/* Card 1 */}
                <ArticleCard className="lg:col-span-2">
                    <CardImage
                        aspectRatio="aspect-[16/9]"
                        src="https://images.unsplash.com/photo-1574169208507-84376144848b?q=80&w=2000&auto=format&fit=crop"
                        alt="Harsh lighting in a concrete room"
                    />
                    <CardMeta>
                        <CardTag>Profile</CardTag>
                        <span>Vol.01</span>
                    </CardMeta>
                    <CardTitle className="text-4xl md:text-5xl">Boy Harsher</CardTitle>
                    <CardExcerpt>
                        The relentless pulse of modern darkwave. Exploring the sweaty, desperate synthesis of 'Careful' and how they weaponize the Roland SH-101 to build cinematic dread in the club.
                    </CardExcerpt>
                    <CardDataPoints
                        data={[
                            { label: "Genre", value: "Darkwave" },
                            { label: "Hardware", value: "SH-101" },
                        ]}
                    />
                </ArticleCard>

                {/* Card 2 */}
                <ArticleCard>
                    <CardImage
                        aspectRatio="aspect-[4/3] lg:aspect-[3/4]"
                        src="https://images.unsplash.com/photo-1520166986518-18e3ab039324?q=80&w=1200&auto=format&fit=crop"
                        alt="Distorted amplifier"
                    />
                    <CardMeta>
                        <CardTag>Retrospective</CardTag>
                        <span>Vol.02</span>
                    </CardMeta>
                    <CardTitle>Yeah Yeah Yeahs</CardTitle>
                    <CardExcerpt>
                        Fever to Tell. The raw, unpolished energy of early 2000s New York post-punk revival. Deconstructing the jagged guitar tones.
                    </CardExcerpt>
                    <CardDataPoints
                        data={[
                            { label: "Era", value: "2003" },
                            { label: "Style", value: "Post-Punk" },
                        ]}
                    />
                </ArticleCard>

                {/* Card 3 */}
                <ArticleCard>
                    <CardImage
                        aspectRatio="aspect-[4/3]"
                        src="https://images.unsplash.com/photo-1508608226992-069a19c36829?q=80&w=1600&auto=format&fit=crop"
                        alt="Desolate urban landscape"
                    />
                    <CardMeta>
                        <CardTag>Scene Report</CardTag>
                        <span>Vol.03</span>
                    </CardMeta>
                    <CardTitle>Lebanon Hanover</CardTitle>
                    <CardExcerpt>
                        Minimalist coldwave and the aesthetics of isolation. Analyzing the stark, algorithmic basslines that soundtrack modern decay.
                    </CardExcerpt>
                    <CardDataPoints
                        data={[
                            { label: "Vibe", value: "Coldwave" },
                            { label: "BPM", value: "115" },
                        ]}
                    />
                </ArticleCard>

                {/* Card 4 */}
                <ArticleCard>
                    <CardImage
                        aspectRatio="aspect-[4/3]"
                        src="https://images.unsplash.com/photo-1598387846148-18d451a37c95?q=80&w=2000&auto=format&fit=crop"
                        alt="Analog Synthesizer Patch Cables"
                    />
                    <CardMeta>
                        <CardTag>Hardware Analysis</CardTag>
                        <span>Sys.01</span>
                    </CardMeta>
                    <CardTitle>KORG MS-20</CardTitle>
                    <CardExcerpt>
                        Why the MS-20's notoriously aggressive high-pass and low-pass filter combination remains the gold standard for tearing through industrial mixes.
                    </CardExcerpt>
                    <CardDataPoints
                        data={[
                            { label: "Type", value: "Semi-Modular" },
                            { label: "Release", value: "1978" },
                        ]}
                    />
                </ArticleCard>

                {/* Card 5 */}
                <ArticleCard>
                    <CardImage
                        aspectRatio="aspect-[4/3]"
                        src="https://images.unsplash.com/photo-1574342267675-27a92fb02b21?q=80&w=2000&auto=format&fit=crop"
                        alt="Dark warehouse club"
                    />
                    <CardMeta>
                        <CardTag>Scene Report</CardTag>
                        <span>Vol.05</span>
                    </CardMeta>
                    <CardTitle>Tresor: The Vault</CardTitle>
                    <CardExcerpt>
                        Exploring the acoustic properties of a decommissioned bank vault and how its physical constraints birthed the dense sound of early 90s Berlin techno.
                    </CardExcerpt>
                    <CardDataPoints
                        data={[
                            { label: "Loc", value: "Berlin, DE" },
                            { label: "BPM", value: "135+" },
                        ]}
                    />
                </ArticleCard>
            </div>
        </main>

        <WaveformSection client:load />
    </div>
</BaseLayout>
