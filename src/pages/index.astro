---
import BaseLayout from "../layouts/BaseLayout.astro";
import { Hero } from "../components/layout/Hero";
import {
    ArticleCard,
    CardMeta,
    CardTag,
    CardImage,
    CardTitle,
    CardExcerpt,
    CardDataPoints,
} from "../components/article/ArticleCard";
import { WaveformSection } from "../components/audio/WaveformSection";
---

<BaseLayout>
    <div class="min-h-screen flex flex-col font-sans bg-background selection:bg-accent selection:text-white">
        <Hero client:load />

        <main class="relative z-10 max-w-[1600px] mx-auto w-full px-4 md:px-8 lg:px-12 pt-40 pb-40">

            {/* Aggressive Hardware Header */}
            <div class="flex flex-col md:flex-row md:items-end justify-between mb-24 pb-10 border-b border-white/[0.05] relative group">
                {/* Glowing Base Line */}
                <div class="absolute bottom-0 left-0 w-full h-[1px] bg-gradient-to-r from-accent via-transparent to-transparent opacity-50"></div>
                <div class="absolute -bottom-[2px] left-0 w-40 h-[3px] bg-accent shadow-[0_0_15px_#ff6000]"></div>

                <div>
                    <div class="flex items-center gap-4 mb-6">
                        <div class="flex items-center gap-2 bg-[#111] border border-white/10 px-3 py-1.5 rounded-lg shadow-inner">
                          <span class="w-2 h-2 bg-accent rounded-full animate-pulse shadow-[0_0_8px_#ff6000]"></span>
                          <span class="font-mono text-[9px] text-white tracking-[0.3em] font-bold uppercase">SYS.OP.01</span>
                        </div>
                        <span class="font-mono text-[10px] text-foreground/40 tracking-[0.2em] uppercase">Status: Online</span>
                    </div>
                    <h2 class="font-serif text-6xl md:text-8xl lg:text-[6rem] font-normal text-white mb-2 tracking-tighter leading-none drop-shadow-lg">Transmissions</h2>
                    <p class="font-sans text-xl text-foreground/50 font-medium mt-6 max-w-xl">Curated archival deep dives, underground scene reports, and structural hardware analyses.</p>
                </div>

                <a href="/essays" class="mt-12 md:mt-0 group/btn inline-flex items-center gap-4 font-sans font-bold text-sm text-white transition-all bg-[#111] px-8 py-4 rounded-2xl border border-white/10 hover:border-accent shadow-[0_10px_20px_rgba(0,0,0,0.5)] hover:shadow-[0_0_30px_rgba(255,96,0,0.2)] hover:-translate-y-1">
                    Access Full Archive
                    <div class="w-8 h-8 rounded-full bg-white/5 flex items-center justify-center group-hover/btn:bg-accent group-hover/btn:text-black transition-colors border border-white/10 group-hover/btn:border-accent">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
                    </div>
                </a>
            </div>

            {/* Asymmetrical Bento Grid */}
            <div class="grid grid-cols-1 md:grid-cols-12 gap-8 lg:gap-10">

                {/* Feature 1 (Massive Span) */}
                <div class="md:col-span-12 lg:col-span-8">
                    <ArticleCard className="h-full">
                        <CardImage
                            aspectRatio="aspect-[16/10] lg:aspect-[21/9]"
                            src="https://images.unsplash.com/photo-1574169208507-84376144848b?q=80&w=2000&auto=format&fit=crop"
                            alt="Harsh lighting in a concrete room"
                        />
                        <CardMeta>
                            <CardTag>Cover Story</CardTag>
                            <span>Vol.01</span>
                        </CardMeta>
                        <CardTitle className="text-5xl md:text-6xl lg:text-7xl mt-2">Boy Harsher</CardTitle>
                        <CardExcerpt className="text-lg md:text-xl max-w-3xl">
                            The relentless pulse of modern darkwave. Exploring the sweaty, desperate synthesis of 'Careful' and how they weaponize the Roland SH-101 to build cinematic dread in the club.
                        </CardExcerpt>
                        <CardDataPoints
                            data={[
                                { label: "Subject", value: "Boy Harsher" },
                                { label: "Genre", value: "Darkwave" },
                                { label: "Hardware", value: "Roland SH-101" },
                            ]}
                        />
                    </ArticleCard>
                </div>

                {/* Feature 2 (Tall Sidebar) */}
                <div class="md:col-span-6 lg:col-span-4">
                    <ArticleCard className="h-full">
                        <CardImage
                            aspectRatio="aspect-[4/3] md:aspect-[3/4]"
                            src="https://images.unsplash.com/photo-1598387846148-18d451a37c95?q=80&w=2000&auto=format&fit=crop"
                            alt="Analog Synthesizer Patch Cables"
                        />
                        <CardMeta>
                            <CardTag>Hardware Analysis</CardTag>
                            <span>Sys.01</span>
                        </CardMeta>
                        <CardTitle className="text-4xl md:text-5xl">KORG MS-20</CardTitle>
                        <CardExcerpt>
                            Why the MS-20's notoriously aggressive high-pass and low-pass filter combination remains the gold standard for tearing through industrial mixes.
                        </CardExcerpt>
                        <CardDataPoints
                            data={[
                                { label: "Type", value: "Semi-Modular" },
                                { label: "Release", value: "1978" },
                            ]}
                        />
                    </ArticleCard>
                </div>

                {/* Feature 3 (Standard) */}
                <div class="md:col-span-6 lg:col-span-4">
                    <ArticleCard className="h-full">
                        <CardImage
                            aspectRatio="aspect-[4/3] lg:aspect-[1/1]"
                            src="https://images.unsplash.com/photo-1520166986518-18e3ab039324?q=80&w=1200&auto=format&fit=crop"
                            alt="Distorted amplifier"
                        />
                        <CardMeta>
                            <CardTag>Retrospective</CardTag>
                            <span>Vol.02</span>
                        </CardMeta>
                        <CardTitle className="text-4xl lg:text-[2.5rem]">Yeah Yeah Yeahs</CardTitle>
                        <CardExcerpt>
                            Fever to Tell. The raw, unpolished energy of early 2000s New York post-punk revival. Deconstructing the jagged guitar tones.
                        </CardExcerpt>
                        <CardDataPoints
                            data={[
                                { label: "Era", value: "2003" },
                                { label: "Style", value: "Post-Punk" },
                            ]}
                        />
                    </ArticleCard>
                </div>

                {/* Feature 4 (Wide Split) */}
                <div class="md:col-span-12 lg:col-span-8">
                    <ArticleCard className="h-full">
                        <div class="flex flex-col lg:flex-row h-full">
                            <div class="w-full lg:w-1/2">
                                <CardImage
                                    aspectRatio="aspect-[16/9] lg:aspect-auto lg:h-full"
                                    src="https://images.unsplash.com/photo-1574342267675-27a92fb02b21?q=80&w=2000&auto=format&fit=crop"
                                    alt="Dark warehouse club"
                                />
                            </div>
                            <div class="w-full lg:w-1/2 flex flex-col justify-between bg-[#08080a] lg:border-l border-white/[0.03]">
                                <div>
                                    <CardMeta>
                                        <CardTag>Scene Report</CardTag>
                                        <span>Vol.05</span>
                                    </CardMeta>
                                    <CardTitle className="text-4xl md:text-5xl mt-2 lg:mt-6">Tresor:<br/>The Vault</CardTitle>
                                    <CardExcerpt className="mt-2">
                                        Exploring the acoustic properties of a decommissioned bank vault and how its physical constraints birthed the dense sound of early 90s Berlin techno.
                                    </CardExcerpt>
                                </div>
                                <div class="mt-auto">
                                    <CardDataPoints
                                        data={[
                                            { label: "Loc", value: "Berlin, DE" },
                                            { label: "BPM", value: "135+" },
                                        ]}
                                    />
                                </div>
                            </div>
                        </div>
                    </ArticleCard>
                </div>

            </div>
        </main>

        <WaveformSection client:load />
    </div>
</BaseLayout>
