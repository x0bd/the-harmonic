---
import BaseLayout from "../../layouts/BaseLayout.astro";
import {
    ArticleCard,
    CardMeta,
    CardImage,
    CardTitle,
    CardExcerpt,
    CardDataPoints,
} from "../../components/article/ArticleCard";
import { ScrambleText } from "../../components/ui/ScrambleText";
import { WaveformSection } from "../../components/audio/WaveformSection";
---

<BaseLayout title="Essays | The Harmonic">
    <div class="min-h-screen flex flex-col font-sans bg-[#030303] selection:bg-[#7b61ff] selection:text-white relative">

        {/* Grain/Noise Overlay */}
        <div class="pointer-events-none fixed inset-0 z-50 opacity-[0.03] mix-blend-overlay" style="background-image: url('data:image/svg+xml,%3Csvg viewBox=%220 0 200 200%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cfilter id=%22noiseFilter%22%3E%3CfeTurbulence type=%22fractalNoise%22 baseFrequency=%220.65%22 numOctaves=%223%22 stitchTiles=%22stitch%22/%3E%3C/filter%3E%3Crect width=%22100%25%22 height=%22100%25%22 filter=%22url(%23noiseFilter)%22/%3E%3C/svg%3E');"></div>

        <main class="relative z-10 w-full max-w-[1600px] mx-auto px-6 md:px-12 lg:px-24 pt-48 pb-64 overflow-hidden">

            {/* Massive Structural Guide Lines */}
            <div class="absolute top-0 bottom-0 left-[10%] w-[1px] bg-white/[0.03] pointer-events-none z-0 hidden lg:block"></div>
            <div class="absolute top-0 bottom-0 right-[10%] w-[1px] bg-white/[0.03] pointer-events-none z-0 hidden lg:block"></div>

            {/* Header Section */}
            <header class="relative w-full mb-24 flex flex-col justify-center items-center text-center border-b border-white/10 pb-24 z-10">
                <div class="flex flex-col group cursor-crosshair relative">
                    {/* Decorative Brackets */}
                    <div class="absolute -left-12 top-0 bottom-0 w-4 border-l border-y border-white/20 hidden md:block"></div>
                    <div class="absolute -right-12 top-0 bottom-0 w-4 border-r border-y border-white/20 hidden md:block"></div>

                    <div class="font-mono text-xs text-[#7b61ff] tracking-[0.4em] uppercase mb-8">
                        <ScrambleText client:visible text="[ DIRECTORY / 001 ]" trigger="load" speed={20} delay={100} />
                    </div>
                    <h1 class="font-sans text-[clamp(4rem,10vw,10rem)] font-black leading-[0.75] tracking-tighter uppercase text-white relative z-10">
                        <ScrambleText client:visible text="ESSAYS" trigger="load" speed={30} delay={200} />
                    </h1>
                    <p class="font-mono text-sm md:text-base text-[#88888D] uppercase tracking-[0.2em] mt-8 max-w-2xl mx-auto">
                        Critical theory, sonic analysis, and cultural observation. The architecture of noise and the structures of sound.
                    </p>
                </div>
            </header>

            {/* Navigation / Filters */}
            <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-8 mb-24 z-10 relative border-b border-white/10 pb-8">
                <div class="flex flex-wrap gap-x-8 gap-y-4 font-mono text-xs tracking-widest uppercase">
                    <button class="text-white border-b border-white pb-1 transition-colors duration-300">
                        All Entries
                    </button>
                    <button class="text-[#88888D] hover:text-white transition-colors duration-300">
                        Theory
                    </button>
                    <button class="text-[#88888D] hover:text-white transition-colors duration-300">
                        Hardware
                    </button>
                    <button class="text-[#88888D] hover:text-white transition-colors duration-300">
                        Culture
                    </button>
                </div>
                <div class="font-mono text-[10px] text-[#88888D] tracking-[0.2em] uppercase flex items-center gap-4">
                    <span>DISPLAY: GRID</span>
                    <span class="w-1 h-1 bg-[#7b61ff]"></span>
                    <span>ENTRIES: 08</span>
                </div>
            </div>

            {/* Brutalist Editorial Grid */}
            <div class="grid grid-cols-1 md:grid-cols-12 gap-x-8 lg:gap-x-12 gap-y-32 relative z-10">

                {/* 1. Lead Feature - Full Width */}
                <div class="md:col-span-12 relative group">
                    <div class="absolute -top-4 -left-4 w-8 h-8 border-t border-l border-[#7b61ff]/0 group-hover:border-[#7b61ff]/50 transition-all duration-700 z-20 pointer-events-none"></div>
                    <a href="/essays/architecture-of-brutalism" class="block">
                        <ArticleCard client:visible>
                            <CardImage
                                aspectRatio="aspect-[16/7]"
                                src="https://images.unsplash.com/photo-1618005182384-a83a8bd57fbe?q=80&w=2500&auto=format&fit=crop"
                                alt="Abstract geometric monoliths"
                            />
                            <CardMeta>
                                <span class="text-[#7b61ff] font-bold tracking-widest">
                                    <ScrambleText client:visible text="CRITICAL THEORY" trigger="hover" speed={15} />
                                </span>
                                <span class="text-white bg-white/10 px-2 py-1 font-mono text-[10px]">2024.10.12</span>
                            </CardMeta>
                            <CardTitle className="text-5xl md:text-7xl lg:text-[7rem] font-black uppercase tracking-tighter mt-4 max-w-5xl">
                                The Architecture<br/>of Brutalism
                            </CardTitle>
                            <CardExcerpt className="mt-8 text-lg md:text-xl lg:text-2xl max-w-4xl text-[#88888D] leading-relaxed">
                                How the post-war concrete movement shaped the sonic landscape of modern techno. We examine the spatial relationship between cold, uncompromising physical structures and the relentless kick drums of the Berlin underground.
                            </CardExcerpt>
                            <CardDataPoints
                                data={[
                                    { label: "FOCUS", value: "ACOUSTICS" },
                                    { label: "ERA", value: "POST-WAR" },
                                    { label: "READ TIME", value: "12 MIN" },
                                ]}
                            />
                        </ArticleCard>
                    </a>
                </div>

                {/* 2. Secondary Feature - Left Aligned */}
                <div class="md:col-span-12 lg:col-span-7 relative">
                    <ArticleCard client:visible>
                        <CardImage
                            aspectRatio="aspect-[4/3]"
                            src="https://images.unsplash.com/photo-1511671782779-c97d3d27a1d4?q=80&w=1600&auto=format&fit=crop"
                            alt="Microphone in studio"
                        />
                        <CardMeta>
                            <span class="text-white tracking-widest">
                                <ScrambleText client:visible text="CULTURE" trigger="hover" speed={15} />
                            </span>
                            <span class="text-[#88888D] font-mono text-[10px]">2024.09.28</span>
                        </CardMeta>
                        <CardTitle className="text-4xl md:text-5xl lg:text-6xl font-black uppercase tracking-tighter mt-4">
                            Ghosts in the<br/>Machine
                        </CardTitle>
                        <CardExcerpt className="mt-6 text-base lg:text-lg text-[#88888D] max-w-xl">
                            Hauntology and the modern obsession with degrading formats. Why producers are spending thousands to make their digital tracks sound like forgotten cassette tapes from 1983.
                        </CardExcerpt>
                        <CardDataPoints
                            data={[
                                { label: "GENRE", value: "AMBIENT" },
                                { label: "READ TIME", value: "8 MIN" },
                            ]}
                        />
                    </ArticleCard>
                </div>

                {/* 3. Deep Dive - Right Aligned Offset */}
                <div class="md:col-span-12 lg:col-span-5 lg:mt-48 relative">
                    <ArticleCard client:visible>
                        <CardImage
                            aspectRatio="aspect-[3/4]"
                            src="https://images.unsplash.com/photo-1550684848-fac1c5b4e853?q=80&w=1200&auto=format&fit=crop"
                            alt="Synthesizer knobs and circuits"
                        />
                        <CardMeta>
                            <span class="text-white tracking-widest">
                                <ScrambleText client:visible text="HARDWARE" trigger="hover" speed={15} />
                            </span>
                            <span class="text-[#88888D] font-mono text-[10px]">2024.08.15</span>
                        </CardMeta>
                        <CardTitle className="text-4xl md:text-5xl font-black uppercase tracking-tighter mt-4">
                            Circuit Bending God
                        </CardTitle>
                        <CardExcerpt className="mt-4 text-base text-[#88888D]">
                            The chaotic beauty of breaking machines to find new sounds. An interview with the pioneers of intentional hardware destruction.
                        </CardExcerpt>
                        <CardDataPoints
                            data={[
                                { label: "TECH", value: "MODULAR" },
                                { label: "READ TIME", value: "15 MIN" },
                            ]}
                        />
                    </ArticleCard>
                </div>

                {/* 4. Small Card - Left */}
                <div class="md:col-span-6 lg:col-span-4 relative">
                    <ArticleCard client:visible>
                        <CardImage
                            aspectRatio="aspect-square"
                            src="https://images.unsplash.com/photo-1520166986518-18e3ab039324?q=80&w=1000&auto=format&fit=crop"
                            alt="Distorted amplifier"
                        />
                        <CardMeta>
                            <span class="text-[#7b61ff] tracking-widest">ANALYSIS</span>
                        </CardMeta>
                        <CardTitle className="text-3xl lg:text-4xl font-black uppercase tracking-tighter mt-4">
                            Maximal Volume
                        </CardTitle>
                        <CardExcerpt className="mt-4 text-sm text-[#88888D]">
                            The loudness war never ended, it just changed frequencies. Examining the mastering techniques of modern hard techno.
                        </CardExcerpt>
                    </ArticleCard>
                </div>

                {/* 5. Wide Card - Right Span */}
                <div class="md:col-span-12 lg:col-span-8 relative">
                    <ArticleCard client:visible>
                        <CardImage
                            aspectRatio="aspect-[16/9]"
                            src="https://images.unsplash.com/photo-1598387181032-a3103a2db5b3?q=80&w=1600&auto=format&fit=crop"
                            alt="Hardware rack"
                        />
                        <CardMeta>
                            <span class="text-white tracking-widest">RETROSPECTIVE</span>
                            <span class="text-[#88888D] font-mono text-[10px]">2024.06.12</span>
                        </CardMeta>
                        <CardTitle className="text-4xl md:text-5xl lg:text-6xl font-black uppercase tracking-tighter mt-4">
                            The Prophet's Voice
                        </CardTitle>
                        <CardExcerpt className="mt-4 text-base lg:text-lg text-[#88888D] max-w-2xl">
                            How Sequential Circuits defined the 1980s and why the Prophet-5 remains the most sought-after polyphonic synthesizer in contemporary industrial music.
                        </CardExcerpt>
                    </ArticleCard>
                </div>

                {/* 6. Standard Portrait */}
                <div class="md:col-span-6 relative">
                    <ArticleCard client:visible>
                        <CardImage
                            aspectRatio="aspect-[4/5]"
                            src="https://images.unsplash.com/photo-1508608226992-069a19c36829?q=80&w=1200&auto=format&fit=crop"
                            alt="Desolate urban landscape"
                        />
                        <CardMeta>
                            <span class="text-white tracking-widest">SCENE REPORT</span>
                        </CardMeta>
                        <CardTitle className="text-4xl font-black uppercase tracking-tighter mt-4">
                            Concrete & Steel
                        </CardTitle>
                        <CardExcerpt className="mt-4 text-base text-[#88888D]">
                            Minimalist coldwave and the aesthetics of isolation. Analyzing the stark, algorithmic basslines of the Eastern European underground.
                        </CardExcerpt>
                    </ArticleCard>
                </div>

                {/* 7. Standard Portrait Offset */}
                <div class="md:col-span-6 lg:mt-24 relative">
                    <ArticleCard client:visible>
                        <CardImage
                            aspectRatio="aspect-[4/5]"
                            src="https://images.unsplash.com/photo-1574342267675-27a92fb02b21?q=80&w=1200&auto=format&fit=crop"
                            alt="Dark warehouse club"
                        />
                        <CardMeta>
                            <span class="text-white tracking-widest">SCENE REPORT</span>
                        </CardMeta>
                        <CardTitle className="text-4xl font-black uppercase tracking-tighter mt-4">
                            The Vault
                        </CardTitle>
                        <CardExcerpt className="mt-4 text-base text-[#88888D]">
                            Exploring the acoustic properties of a decommissioned bank vault and how physical constraints birth dense, relentless sound.
                        </CardExcerpt>
                    </ArticleCard>
                </div>

                {/* 8. Footer Feature - Split Layout */}
                <div class="md:col-span-12 relative mt-16 pt-16 border-t border-white/10 group">
                    <ArticleCard client:visible>
                        <div class="flex flex-col md:flex-row gap-8 lg:gap-16 items-center">
                            <div class="w-full md:w-1/2 flex-shrink-0">
                                <CardImage
                                    aspectRatio="aspect-[16/10]"
                                    src="https://images.unsplash.com/photo-1615554851446-4dc113c4a22b?q=80&w=2000&auto=format&fit=crop"
                                    alt="Dark empty warehouse"
                                />
                            </div>
                            <div class="w-full md:w-1/2 flex flex-col justify-center">
                                <CardMeta>
                                    <span class="text-[#7b61ff] font-bold tracking-widest">
                                        <ScrambleText client:visible text="ESSAY" trigger="hover" speed={15} />
                                    </span>
                                    <span class="text-white bg-white/10 px-2 py-1 font-mono text-[10px]">2024.05.01</span>
                                </CardMeta>
                                <CardTitle className="text-4xl md:text-5xl lg:text-6xl font-black uppercase tracking-tighter mt-4">
                                    The Empty Space
                                </CardTitle>
                                <CardExcerpt className="mt-6 text-base lg:text-lg text-[#88888D]">
                                    Silence is not the absence of sound, but the canvas it demands. How contemporary ambient artists use massive reverb algorithms to construct cathedrals of nothingness.
                                </CardExcerpt>
                                <CardDataPoints
                                    data={[
                                        { label: "STYLE", value: "DRONE" },
                                        { label: "READ TIME", value: "6 MIN" },
                                    ]}
                                />
                            </div>
                        </div>
                    </ArticleCard>
                </div>

            </div>

            {/* Load More Trigger */}
            <div class="w-full flex justify-center mt-32 mb-16 relative z-10">
                <button class="font-mono text-xs text-white uppercase tracking-[0.2em] border border-white/20 px-8 py-4 hover:bg-white hover:text-black transition-colors duration-300 flex items-center gap-4 group">
                    <span>Load Archive</span>
                    <span class="group-hover:translate-y-1 transition-transform">↓</span>
                </button>
            </div>

        </main>

        <div class="border-t border-white/10 bg-[#060606] pt-16 relative z-10">
            <WaveformSection client:load />
        </div>
    </div>
</BaseLayout>
