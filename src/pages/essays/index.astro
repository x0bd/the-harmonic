---
import BaseLayout from "../../layouts/BaseLayout.astro";
import {
    ArticleCard,
    CardMeta,
    CardTag,
    CardImage,
    CardTitle,
    CardExcerpt,
    CardDataPoints,
} from "../../components/article/ArticleCard";
import { WaveformSection } from "../../components/audio/WaveformSection";
---

<BaseLayout title="Essays | The Harmonic">
    <div class="min-h-screen flex flex-col font-sans bg-background selection:bg-accent selection:text-white relative">

        <main class="relative z-10 w-full max-w-[1600px] mx-auto px-4 md:px-8 lg:px-12 pt-40 pb-40 overflow-hidden">

            {/* Aggressive Hardware Header */}
            <header class="w-full mb-20 relative">
                {/* Background Track */}
                <div class="absolute top-1/2 left-0 w-full h-[1px] bg-white/5 -translate-y-1/2 -z-10 hidden md:block"></div>

                <div class="inline-block bg-background pr-8 relative z-10">
                    <div class="flex items-center gap-3 mb-4">
                        <div class="w-2 h-2 bg-accent rounded-sm shadow-[0_0_12px_#ff6000] rotate-45"></div>
                        <span class="font-mono text-[10px] text-foreground/40 uppercase tracking-[0.3em] font-bold">Directory // 01</span>
                    </div>
                    <h1 class="font-serif text-6xl md:text-8xl lg:text-[7rem] tracking-tighter text-white leading-none drop-shadow-lg">
                        Essays <span class="text-accent italic">&</span> <br class="hidden md:block" /> Analysis
                    </h1>
                </div>
            </header>

            {/* Hardware Filter Bar */}
            <div class="flex flex-col md:flex-row justify-between items-start md:items-end gap-8 mb-24 relative bg-[#0c0c0e] p-6 md:p-8 rounded-[2rem] border border-white/[0.05] shadow-[0_20px_40px_rgba(0,0,0,0.4),inset_0_1px_1px_rgba(255,255,255,0.05)]">

                {/* Physical Tabs */}
                <div class="flex flex-wrap gap-3 font-mono text-[10px] tracking-[0.2em] uppercase font-bold">
                    <button class="bg-accent text-black px-6 py-3 rounded-xl shadow-[0_0_15px_rgba(255,96,0,0.3),inset_0_2px_4px_rgba(255,255,255,0.4)] transition-all">
                        All
                    </button>
                    <button class="bg-[#151515] text-foreground/50 border border-white/10 px-6 py-3 rounded-xl hover:bg-white/5 hover:text-white transition-all shadow-[inset_0_2px_4px_rgba(0,0,0,0.5)]">
                        Theory
                    </button>
                    <button class="bg-[#151515] text-foreground/50 border border-white/10 px-6 py-3 rounded-xl hover:bg-white/5 hover:text-white transition-all shadow-[inset_0_2px_4px_rgba(0,0,0,0.5)]">
                        Hardware
                    </button>
                    <button class="bg-[#151515] text-foreground/50 border border-white/10 px-6 py-3 rounded-xl hover:bg-white/5 hover:text-white transition-all shadow-[inset_0_2px_4px_rgba(0,0,0,0.5)]">
                        Culture
                    </button>
                </div>

                {/* Technical Readout */}
                <div class="flex flex-col items-end gap-2 font-mono text-[9px] text-foreground/40 tracking-[0.25em] uppercase">
                    <div class="flex items-center gap-3">
                        <span>Display: Grid</span>
                        <div class="flex gap-1">
                            <span class="w-1.5 h-1.5 bg-accent rounded-sm opacity-50"></span>
                            <span class="w-1.5 h-1.5 bg-accent rounded-sm opacity-50"></span>
                            <span class="w-1.5 h-1.5 bg-accent rounded-sm shadow-[0_0_8px_#ff6000]"></span>
                        </div>
                    </div>
                    <span>Entries_Found: 08</span>
                </div>
            </div>

            {/* Asymmetrical Bento Grid (Inheriting the updated ArticleCard styles) */}
            <div class="grid grid-cols-1 md:grid-cols-12 gap-6 lg:gap-10 relative z-10">

                {/* 1. Lead Feature - Massive Wide Hero */}
                <div class="md:col-span-12 relative group">
                    <a href="/essays/architecture-of-brutalism" class="block h-full">
                        <ArticleCard className="h-full">
                            <div class="flex flex-col lg:flex-row h-full">
                                <div class="w-full lg:w-[60%]">
                                    <CardImage
                                        aspectRatio="aspect-[16/9] lg:aspect-auto lg:h-full"
                                        src="https://images.unsplash.com/photo-1618005182384-a83a8bd57fbe?q=80&w=2500&auto=format&fit=crop"
                                        alt="Abstract geometric monoliths"
                                    />
                                </div>
                                <div class="w-full lg:w-[40%] flex flex-col justify-between bg-[#08080a] lg:border-l border-white/[0.03]">
                                    <div>
                                        <CardMeta>
                                            <CardTag>Critical Theory</CardTag>
                                            <span class="font-mono text-[9px]">2024.10.12</span>
                                        </CardMeta>
                                        <CardTitle className="text-4xl md:text-5xl lg:text-6xl mt-4">
                                            The Architecture of Brutalism
                                        </CardTitle>
                                        <CardExcerpt className="mt-4">
                                            How the post-war concrete movement shaped the sonic landscape of modern techno. We examine the spatial relationship between cold, uncompromising physical structures and the relentless kick drums of the Berlin underground.
                                        </CardExcerpt>
                                    </div>
                                    <div class="mt-auto">
                                        <CardDataPoints
                                            data={[
                                                { label: "Focus", value: "Acoustics" },
                                                { label: "Time", value: "12 Min" },
                                            ]}
                                        />
                                    </div>
                                </div>
                            </div>
                        </ArticleCard>
                    </a>
                </div>

                {/* 2. Secondary Feature - Standard */}
                <div class="md:col-span-6 lg:col-span-7 relative">
                    <ArticleCard className="h-full">
                        <CardImage
                            aspectRatio="aspect-[4/3] lg:aspect-[16/10]"
                            src="https://images.unsplash.com/photo-1511671782779-c97d3d27a1d4?q=80&w=1600&auto=format&fit=crop"
                            alt="Microphone in studio"
                        />
                        <CardMeta>
                            <CardTag>Culture</CardTag>
                            <span class="font-mono text-[9px]">2024.09.28</span>
                        </CardMeta>
                        <CardTitle className="text-4xl lg:text-5xl mt-2">
                            Ghosts in the Machine
                        </CardTitle>
                        <CardExcerpt className="mt-2">
                            Hauntology and the modern obsession with degrading formats. Why producers are spending thousands to make their digital tracks sound like forgotten cassette tapes from 1983.
                        </CardExcerpt>
                        <div class="mt-auto">
                            <CardDataPoints
                                data={[
                                    { label: "Genre", value: "Ambient" },
                                    { label: "Time", value: "8 Min" },
                                ]}
                            />
                        </div>
                    </ArticleCard>
                </div>

                {/* 3. Deep Dive - Tall Sidebar */}
                <div class="md:col-span-6 lg:col-span-5 relative">
                    <ArticleCard className="h-full">
                        <CardImage
                            aspectRatio="aspect-[4/3] lg:aspect-[3/4]"
                            src="https://images.unsplash.com/photo-1550684848-fac1c5b4e853?q=80&w=1200&auto=format&fit=crop"
                            alt="Synthesizer knobs and circuits"
                        />
                        <CardMeta>
                            <CardTag>Hardware</CardTag>
                            <span class="font-mono text-[9px]">2024.08.15</span>
                        </CardMeta>
                        <CardTitle className="text-4xl lg:text-5xl mt-2">
                            Circuit Bending God
                        </CardTitle>
                        <CardExcerpt className="mt-2">
                            The chaotic beauty of breaking machines to find new sounds. An interview with the pioneers of intentional hardware destruction.
                        </CardExcerpt>
                         <div class="mt-auto">
                            <CardDataPoints
                                data={[
                                    { label: "Subject", value: "Modding" },
                                    { label: "Time", value: "15 Min" },
                                ]}
                            />
                        </div>
                    </ArticleCard>
                </div>

                {/* 4. Wide Panorama - Center Span */}
                <div class="md:col-span-12 relative">
                    <ArticleCard className="h-full">
                        <CardImage
                            aspectRatio="aspect-[16/6] lg:aspect-[21/7]"
                            src="https://images.unsplash.com/photo-1598387181032-a3103a2db5b3?q=80&w=1600&auto=format&fit=crop"
                            alt="Hardware rack"
                        />
                        <div class="grid grid-cols-1 lg:grid-cols-2 gap-0 lg:gap-12">
                            <div>
                                <CardMeta>
                                    <CardTag>Retrospective</CardTag>
                                    <span class="font-mono text-[9px]">2024.06.12</span>
                                </CardMeta>
                                <CardTitle className="text-4xl md:text-5xl lg:text-6xl mt-2">
                                    The Prophet's Voice
                                </CardTitle>
                            </div>
                            <div class="lg:mt-8 flex flex-col justify-end">
                                <CardExcerpt className="text-lg">
                                    How Sequential Circuits defined the 1980s and why the Prophet-5 remains the most sought-after polyphonic synthesizer in contemporary industrial music.
                                </CardExcerpt>
                            </div>
                        </div>
                    </ArticleCard>
                </div>

                {/* 5. Small Card - Left */}
                <div class="md:col-span-6 lg:col-span-6 relative">
                    <ArticleCard className="h-full">
                        <CardImage
                            aspectRatio="aspect-[4/3]"
                            src="https://images.unsplash.com/photo-1520166986518-18e3ab039324?q=80&w=1000&auto=format&fit=crop"
                            alt="Distorted amplifier"
                        />
                        <CardMeta>
                            <CardTag>Analysis</CardTag>
                            <span class="font-mono text-[9px]">2024.07.22</span>
                        </CardMeta>
                        <CardTitle className="text-3xl md:text-4xl mt-2">
                            Maximal Volume
                        </CardTitle>
                        <CardExcerpt className="mt-2">
                            The loudness war never ended, it just changed frequencies.
                        </CardExcerpt>
                    </ArticleCard>
                </div>

                {/* 6. Standard - Right */}
                <div class="md:col-span-6 lg:col-span-6 relative">
                    <ArticleCard className="h-full">
                        <CardImage
                            aspectRatio="aspect-[4/3]"
                            src="https://images.unsplash.com/photo-1508608226992-069a19c36829?q=80&w=1200&auto=format&fit=crop"
                            alt="Desolate urban landscape"
                        />
                        <CardMeta>
                            <CardTag>Scene Report</CardTag>
                            <span class="font-mono text-[9px]">2024.05.01</span>
                        </CardMeta>
                        <CardTitle className="text-3xl md:text-4xl mt-2">
                            Concrete & Steel
                        </CardTitle>
                        <CardExcerpt className="mt-2">
                            Minimalist coldwave and the aesthetics of isolation. Analyzing the stark, algorithmic basslines of the Eastern European underground.
                        </CardExcerpt>
                    </ArticleCard>
                </div>

            </div>

            {/* Hardware Load More Trigger */}
            <div class="w-full flex justify-center mt-32 relative z-10">
                <button class="group/btn relative overflow-hidden bg-[#111] border border-white/10 rounded-2xl px-10 py-5 flex items-center gap-4 transition-all duration-300 hover:border-accent shadow-[0_10px_20px_rgba(0,0,0,0.5)] hover:shadow-[0_0_30px_rgba(255,96,0,0.2)] hover:-translate-y-1">
                    <div class="absolute inset-0 bg-gradient-to-b from-white/[0.05] to-transparent pointer-events-none"></div>
                    <span class="w-2 h-2 bg-accent rounded-full shadow-[0_0_8px_#ff6000] group-hover/btn:animate-ping"></span>
                    <span class="font-mono text-xs text-white uppercase tracking-[0.2em] font-bold">Load Archive</span>
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-foreground/50 group-hover/btn:text-accent transition-colors group-hover/btn:translate-y-1 duration-300"><line x1="12" y1="5" x2="12" y2="19"></line><polyline points="19 12 12 19 5 12"></polyline></svg>
                </button>
            </div>

        </main>

        <div class="relative z-10 w-full max-w-[1600px] mx-auto pb-8">
            <WaveformSection client:load />
        </div>
    </div>
</BaseLayout>
