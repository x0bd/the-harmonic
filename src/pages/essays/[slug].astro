---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { ScrambleText } from '../../components/ui/ScrambleText';

export async function getStaticPaths() {
  const essayEntries = await getCollection('essays');
  return essayEntries.map(entry => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<BaseLayout title={`${entry.data.title} | The Harmonic`}>
    <article class="min-h-screen flex flex-col font-sans bg-[#030303] selection:bg-[#7b61ff] selection:text-white relative pb-32">
        {/* Grain Overlay */}
        <div class="pointer-events-none fixed inset-0 z-50 opacity-[0.03] mix-blend-overlay" style="background-image: url('data:image/svg+xml,%3Csvg viewBox=%220 0 200 200%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cfilter id=%22noiseFilter%22%3E%3CfeTurbulence type=%22fractalNoise%22 baseFrequency=%220.65%22 numOctaves=%223%22 stitchTiles=%22stitch%22/%3E%3C/filter%3E%3Crect width=%22100%25%22 height=%22100%25%22 filter=%22url(%23noiseFilter)%22/%3E%3C/svg%3E');"></div>

        {/* Hero Section */}
        <header class="relative w-full flex flex-col pt-32 pb-16 z-10">
            <div class="w-full max-w-[1600px] mx-auto px-6 md:px-12 lg:px-24 mb-16 relative">
                 {/* Top Meta Line */}
                 <div class="flex items-center gap-6 font-mono text-[10px] text-[#88888D] uppercase tracking-widest border-b border-white/10 pb-6 mb-12">
                    <span class="text-[#7b61ff]">[{entry.data.category}]</span>
                    <span class="w-[1px] h-3 bg-white/20"></span>
                    <span>{entry.data.readingTime} READ</span>
                    <span class="w-[1px] h-3 bg-white/20"></span>
                    <span>{entry.data.date.toISOString().split('T')[0]}</span>
                </div>

                {/* Left-Aligned, Sharper Title */}
                <div class="flex flex-col group cursor-crosshair">
                    <h1 class="font-sans text-5xl md:text-6xl lg:text-[5rem] font-black leading-[0.9] tracking-tighter uppercase text-white mb-8 max-w-5xl">
                        {entry.data.title}
                    </h1>

                    {entry.data.subtitle && (
                        <p class="font-mono text-base md:text-lg text-[#88888D] uppercase tracking-[0.1em] max-w-2xl border-l-2 border-[#7b61ff] pl-6">
                            {entry.data.subtitle}
                        </p>
                    )}
                </div>

                <div class="mt-12 flex gap-3 font-mono text-[10px] uppercase tracking-widest text-[#88888D]">
                    {entry.data.tags?.map((tag: string) => (
                        <span class="border border-white/10 px-3 py-1 bg-white/5">{tag}</span>
                    ))}
                </div>
            </div>

            {/* Massive Hero Image Block */}
            <div class="w-full h-[60vh] min-h-[500px] relative border-y border-white/10">
                 {/* Crosshairs on image */}
                <div class="absolute top-6 left-6 w-4 h-4 border-t-2 border-l-2 border-white/30 z-10"></div>
                <div class="absolute bottom-6 right-6 w-4 h-4 border-b-2 border-r-2 border-white/30 z-10"></div>

                <img src={entry.data.coverImage} alt={entry.data.coverImageAlt || entry.data.title} class="w-full h-full object-cover grayscale contrast-125 brightness-75" />
            </div>
        </header>

        {/* Content Section - Breakout Strategy */}
        <main class="relative z-10 w-full pt-16 flex flex-col items-center">
            {/*
                We remove prose constraints from the parent so children can dictate their own width.
                We use a custom prose class strategy to target the standard markdown elements
                while leaving custom React components untouched.
            */}
            <div class="w-full prose prose-invert prose-lg md:prose-xl
                        prose-p:max-w-3xl prose-p:mx-auto prose-p:px-6 prose-p:font-mono prose-p:text-[#88888D] prose-p:leading-relaxed
                        prose-headings:max-w-3xl prose-headings:mx-auto prose-headings:px-6 prose-headings:font-sans prose-headings:uppercase prose-headings:tracking-tighter prose-headings:text-white prose-headings:mt-16 prose-headings:mb-8
                        prose-a:text-[#7b61ff] hover:prose-a:text-white
                        prose-blockquote:max-w-4xl prose-blockquote:mx-auto prose-blockquote:px-8 prose-blockquote:border-[#7b61ff] prose-blockquote:text-white prose-blockquote:font-sans prose-blockquote:text-2xl md:prose-blockquote:text-3xl prose-blockquote:not-italic prose-blockquote:uppercase prose-blockquote:tracking-tight prose-blockquote:my-16
                        prose-ul:max-w-3xl prose-ul:mx-auto prose-ul:px-6 prose-ul:font-mono prose-ul:text-[#88888D]
                        prose-li:marker:text-[#7b61ff]
                        prose-strong:text-white">
                <Content />
            </div>
        </main>
    </article>
</BaseLayout>
