---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { ScrambleText } from '../../components/ui/ScrambleText';

export async function getStaticPaths() {
  const essayEntries = await getCollection('essays');
  return essayEntries.map(entry => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<BaseLayout title={`${entry.data.title} | The Harmonic`}>
    <article class="min-h-screen flex flex-col font-sans bg-[#030303] selection:bg-[#7b61ff] selection:text-white relative pb-32">
        {/* Grain Overlay */}
        <div class="pointer-events-none fixed inset-0 z-50 opacity-[0.03] mix-blend-overlay" style="background-image: url('data:image/svg+xml,%3Csvg viewBox=%220 0 200 200%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cfilter id=%22noiseFilter%22%3E%3CfeTurbulence type=%22fractalNoise%22 baseFrequency=%220.65%22 numOctaves=%223%22 stitchTiles=%22stitch%22/%3E%3C/filter%3E%3Crect width=%22100%25%22 height=%22100%25%22 filter=%22url(%23noiseFilter)%22/%3E%3C/svg%3E');"></div>

        {/* Hero Section */}
        <header class="relative w-full h-[80vh] min-h-[600px] flex flex-col justify-end items-center text-center pb-24 z-10 overflow-hidden">
            {/* Background Image */}
            <div class="absolute inset-0 z-0">
                <img src={entry.data.coverImage} alt={entry.data.coverImageAlt || entry.data.title} class="w-full h-full object-cover grayscale contrast-125 brightness-50" />
                <div class="absolute inset-0 bg-gradient-to-t from-[#030303] via-[#030303]/80 to-transparent"></div>
            </div>

            <div class="relative z-10 w-full max-w-5xl mx-auto px-6 flex flex-col items-center group cursor-crosshair">
                <div class="font-mono text-xs md:text-sm text-[#7b61ff] tracking-[0.4em] uppercase mb-8 flex items-center gap-4">
                    <span>{entry.data.category}</span>
                    <span class="w-1 h-1 bg-white"></span>
                    <span>{entry.data.readingTime}</span>
                </div>

                <h1 class="font-sans text-[clamp(3rem,8vw,8rem)] font-black leading-[0.85] tracking-tighter uppercase text-white mb-8">
                    <ScrambleText client:visible text={entry.data.title} trigger="load" speed={30} delay={100} />
                </h1>

                {entry.data.subtitle && (
                    <p class="font-mono text-base md:text-lg text-[#88888D] uppercase tracking-[0.1em] max-w-3xl mb-12 border-l-2 border-[#7b61ff] pl-6 text-left">
                        {entry.data.subtitle}
                    </p>
                )}

                <div class="flex items-center gap-8 font-mono text-[10px] text-white/50 tracking-widest uppercase border-t border-white/10 pt-8 w-full justify-center">
                    <span>BY {entry.data.author}</span>
                    <span>{entry.data.date.toISOString().split('T')[0]}</span>
                    <div class="flex gap-4">
                        {entry.data.tags?.map((tag: string) => (
                            <span class="border border-white/20 px-2 py-1">{tag}</span>
                        ))}
                    </div>
                </div>
            </div>
        </header>

        {/* Content Section - Strict Central Column */}
        <main class="relative z-10 w-full max-w-3xl mx-auto px-6 md:px-12 pt-16 prose prose-invert prose-lg md:prose-xl prose-p:font-mono prose-p:text-[#88888D] prose-p:leading-relaxed prose-headings:font-sans prose-headings:uppercase prose-headings:tracking-tighter prose-headings:text-white prose-a:text-[#7b61ff] hover:prose-a:text-white prose-blockquote:border-[#7b61ff] prose-blockquote:text-white prose-blockquote:font-sans prose-blockquote:text-2xl prose-blockquote:not-italic prose-blockquote:uppercase prose-blockquote:tracking-tight prose-strong:text-white">
            <Content />
        </main>
    </article>
</BaseLayout>
