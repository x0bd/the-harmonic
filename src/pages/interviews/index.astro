---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { ScrambleText } from "../../components/ui/ScrambleText";

const interviews = [
  {
    id: "004",
    tag: "CONVERSATION",
    title: "Silence as Velocity: The Space Between Kicks",
    date: "24.10.23",
    url: "/interviews/silence-as-velocity"
  },
  {
    id: "003",
    tag: "STUDIO VISIT",
    title: "Granular Synthesis Patterns with Boy Harsher",
    date: "18.09.23",
    url: "/interviews/granular-synthesis-patterns"
  },
  {
    id: "002",
    tag: "PROFILE",
    title: "Rhythm and Void: Tokyo Underground",
    date: "02.08.23",
    url: "/interviews/tokyo-underground"
  },
  {
    id: "001",
    tag: "MANIFESTO",
    title: "Frequencies of Resistance",
    date: "14.07.23",
    url: "/interviews/frequencies-of-resistance"
  },
  {
    id: "000",
    tag: "ARCHIVE",
    title: "The Architecture of Brutalism",
    date: "01.05.23",
    url: "/interviews/architecture-of-brutalism"
  }
];
---

<BaseLayout title="Interviews | The Harmonic">
    <div class="min-h-screen flex flex-col font-mono bg-[#030303] selection:bg-[#7b61ff] selection:text-white relative text-[#88888D]">

        {/* Grain/Noise Overlay */}
        <div class="pointer-events-none fixed inset-0 z-50 opacity-[0.03] mix-blend-overlay" style="background-image: url('data:image/svg+xml,%3Csvg viewBox=%220 0 200 200%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cfilter id=%22noiseFilter%22%3E%3CfeTurbulence type=%22fractalNoise%22 baseFrequency=%220.65%22 numOctaves=%223%22 stitchTiles=%22stitch%22/%3E%3C/filter%3E%3Crect width=%22100%25%22 height=%22100%25%22 filter=%22url(%23noiseFilter)%22/%3E%3C/svg%3E');"></div>

        <main class="relative z-10 w-full max-w-screen-2xl mx-auto px-6 md:px-12 lg:px-24 pt-32 pb-64 flex flex-col min-h-screen">

            {/* Minimalist Header Section */}
            <header class="w-full mb-32 z-10 relative flex justify-start">
                <h1 class="font-serif text-3xl md:text-5xl tracking-normal text-white capitalize group cursor-crosshair">
                    <ScrambleText client:visible text="Conversations in the Void" trigger="load" speed={30} delay={200} />
                </h1>
            </header>

            {/* List Header */}
            <div class="flex justify-between items-end border-b border-white/10 pb-4 mb-4 text-[10px] md:text-xs uppercase tracking-[0.2em] mt-auto md:mt-0">
                <h2 class="text-white">
                    <ScrambleText client:visible text="ARCHIVE INDEX" trigger="load" speed={20} delay={400} />
                </h2>
                <span>[ SORT: CHRONOLOGICAL ]</span>
            </div>

            {/* Interactive List */}
            <div class="flex flex-col w-full">
                {interviews.map((item) => (
                    <a href={item.url} class="group flex flex-col border-b border-white/5 hover:border-white/20 transition-colors duration-500 py-6 md:py-10 cursor-crosshair">
                        <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 md:gap-8 w-full">

                            {/* Meta Left */}
                            <div class="flex items-center gap-8 md:gap-16 md:w-1/4 flex-shrink-0">
                                <span class="text-[10px] tracking-widest text-[#555555] group-hover:text-white transition-colors duration-300">
                                    {item.id}
                                </span>
                                <span class="text-[10px] tracking-[0.2em] text-[#88888D] group-hover:text-white transition-colors duration-300">
                                    {item.tag}
                                </span>
                            </div>

                            {/* Title - Center */}
                            <div class="flex-grow">
                                <h3 class="font-serif text-xl md:text-2xl lg:text-3xl text-[#cccccc] group-hover:text-white transition-colors duration-300 font-normal tracking-wide">
                                    {item.title}
                                </h3>
                            </div>

                            {/* Meta Right */}
                            <div class="flex items-center justify-between md:justify-end gap-8 md:gap-16 md:w-1/4 flex-shrink-0 mt-4 md:mt-0">
                                <span class="text-[10px] tracking-widest text-[#555555] group-hover:text-white transition-colors duration-300">
                                    {item.date}
                                </span>
                                <span class="text-xs text-[#555555] group-hover:text-white transition-colors duration-300 font-mono">
                                    [+]
                                </span>
                            </div>

                        </div>
                    </a>
                ))}
            </div>

        </main>
    </div>
</BaseLayout>
