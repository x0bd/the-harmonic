{
  "kind": "collectionType",
  "collectionName": "artists",
  "info": {
    "singularName": "artist",
    "pluralName": "artists",
    "displayName": "Artist"
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "name",
      "required": true
    },
    "location": {
      "type": "string"
    },
    "genres": {
      "type": "json"
    },
    "shortBio": {
      "type": "text"
    },
    "bio": {
      "type": "richtext"
    },
    "heroImage": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images"
      ]
    },
    "avatar": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images"
      ]
    },
    "releases": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::release.release",
      "mappedBy": "artist"
    },
    "interviews": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::interview.interview",
      "mappedBy": "subject"
    },
    "articles": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::article.article",
      "mappedBy": "artist"
    },
    "scenes": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::scene.scene",
      "mappedBy": "artists"
    }
  }
}

