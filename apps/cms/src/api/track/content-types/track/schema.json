{
  "kind": "collectionType",
  "collectionName": "tracks",
  "info": {
    "singularName": "track",
    "pluralName": "tracks",
    "displayName": "Track"
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "trackNumber": {
      "type": "integer",
      "required": true,
      "min": 1
    },
    "durationSeconds": {
      "type": "integer",
      "min": 1
    },
    "bpm": {
      "type": "integer",
      "min": 1
    },
    "musicalKey": {
      "type": "string"
    },
    "audioFile": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "audios"
      ]
    },
    "release": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::release.release",
      "inversedBy": "tracks"
    }
  }
}

